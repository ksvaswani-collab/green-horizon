---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Green Horizon — A cliff-edge hotel on Bulgaria's Black Sea coast",
  description = "Green Horizon is a family-built boutique hotel perched on an ancient volcanic cliff above the Black Sea. Opening 2026.",
} = Astro.props;

import '../styles/v3.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <a href="#main-content" class="v3-skip">Skip to main content</a>

  <header class="v3-nav" id="v3-nav">
    <div class="v3-nav-inner">
      <a href="/v3/" class="v3-nav-wordmark">Green Horizon</a>
      <nav class="v3-nav-links" id="v3-nav-links" aria-label="Main navigation">
        <a href="#" class="v3-nav-link">Our Story</a>
        <a href="#" class="v3-nav-link">Elements</a>
        <a href="#" class="v3-nav-link">Experiences</a>
        <a href="#" class="v3-nav-link">The Build</a>
        <a href="#" class="v3-nav-link">Suites</a>
      </nav>
      <div class="v3-nav-right">
        <a href="#" class="v3-nav-cta">Register interest</a>
        <button
          class="v3-hamburger"
          aria-expanded="false"
          aria-controls="v3-nav-links"
          aria-label="Toggle menu"
        >
          <span class="v3-burger-line"></span>
          <span class="v3-burger-line"></span>
          <span class="v3-burger-line v3-burger-short"></span>
        </button>
      </div>
    </div>
  </header>

  <main class="v3-main" id="main-content" tabindex="-1">
    <slot />
  </main>

  <script>
    import AOS from 'aos'
    import 'aos/dist/aos.css'

    AOS.init({
      duration: 750,
      easing: 'ease-out',
      once: true,
      offset: 80,
      delay: 0,
    })

    // Nav scroll state
    const nav = document.getElementById('v3-nav')
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('v3-nav--scrolled', window.scrollY > 48)
    }, { passive: true })

    // Hamburger
    const hamburger = document.querySelector('.v3-hamburger') as HTMLButtonElement
    const navLinks  = document.getElementById('v3-nav-links')
    hamburger?.addEventListener('click', () => {
      const open = navLinks?.classList.toggle('v3-nav-links--open')
      hamburger.setAttribute('aria-expanded', String(open))
      document.body.classList.toggle('v3-no-scroll', !!open)
    })

    // Prevent nav links from scrolling to sections
    document.querySelectorAll('.v3-nav-link').forEach(link => {
      link.addEventListener('click', e => e.preventDefault())
    })
  </script>
</body>
</html>

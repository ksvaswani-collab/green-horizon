import StorySection from '../../components/v3/StorySection.astro';
import ElementsSection from '../../components/v3/ElementsSection.astro';
import ExperiencesSection from '../../components/v3/ExperiencesSection.astro';
import JourneySection from '../../components/v3/JourneySection.astro';

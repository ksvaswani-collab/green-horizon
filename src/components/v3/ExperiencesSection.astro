---
const experiences = [
  { n:'01', label:'Strandzha to the north', heading:'On the cliff path.', body:'The path runs north along the cliff top for eleven kilometres, passing three villages and two cape headlands before turning inland near the nature reserve at Yaylata. Start from the hotel gate at first light. Return for lunch.', src:'/images/exp-forest.jpg', alt:'The cliff path heading north through ancient Strandzha forest' },
  { n:'02', label:'One sitting. One menu.', heading:'At the table.', body:'The kitchen is not a restaurant. One sitting per service, built from what has arrived that morning. Wine is Bulgarian. You may bring your own — we will not charge corkage.', src:'/images/exp-dunes.jpg', alt:'The open-air dining terrace at golden hour' },
  { n:'03', label:'By kayak, by foot, or by swimming', heading:'On the water.', body:'At the base of the cliff, accessed by a cut staircase through the rock, a simple landing dock. Kayaks for independent use. Fishing trips arranged with the men from Kamen Bryag.', src:'/images/exp-sea.jpg', alt:'The Black Sea from the cliff base, morning light' },
]
---
<section id="experiences" class="exp" aria-labelledby="exp-heading">
  <header class="exp-header">
    <p class="exp-overline">Experiences</p>
    <h2 class="exp-title" id="exp-heading">The Black Sea,<br>your way.</h2>
  </header>
  <div class="exp-list">
    {experiences.map((item) => (
      <article class="exp-entry v3-reveal" aria-label={item.heading}>
        <div class="exp-entry-top">
          <span class="exp-n" aria-hidden="true">{item.n}</span>
          <p class="exp-label">{item.label}</p>
        </div>
        <div class="exp-img-wrap">
          <img class="exp-img" src={item.src} alt={item.alt} loading="lazy" />
        </div>
        <div class="exp-text">
          <h3 class="exp-heading">{item.heading}</h3>
          <p class="exp-body">{item.body}</p>
        </div>
        <hr class="exp-rule" aria-hidden="true" />
      </article>
    ))}
  </div>
</section>
<style>
  .exp{background:var(--v3-bg);padding:5rem clamp(2rem,6vw,6rem) 0}
  .exp-header{max-width:80rem;margin:0 auto 4rem;display:flex;align-items:flex-start;gap:3rem}
  .exp-overline{font-family:var(--font-v3-fine);font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--v3-muted);margin:0;white-space:nowrap;padding-top:.4rem}
  .exp-title{font-family:var(--font-v3-primary);font-style:italic;font-size:clamp(2.2rem,5vw,4.5rem);line-height:1.05;color:var(--v3-ink);font-weight:400;margin:0;letter-spacing:-.02em}
  .exp-list{max-width:80rem;margin:0 auto}
  .exp-entry{padding:3rem 0 0}
  .exp-entry-top{display:flex;align-items:baseline;gap:1.5rem;margin-bottom:1.5rem}
  .exp-n{font-family:var(--font-v3-primary);font-style:italic;font-size:clamp(4rem,8vw,8rem);line-height:.85;color:rgba(26,21,16,.09);font-weight:400;user-select:none;flex-shrink:0;margin-bottom:-1rem}
  .exp-label{font-family:var(--font-v3-fine);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--v3-muted);margin:0}
  .exp-img-wrap{width:100%;overflow:hidden}
  .exp-img{width:100%;aspect-ratio:21/9;object-fit:cover;display:block;filter:brightness(.95) contrast(1.03);transition:transform .7s ease}
  .exp-img-wrap:hover .exp-img{transform:scale(1.02)}
  .exp-text{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start;padding:1.5rem 0 2rem}
  .exp-heading{font-family:var(--font-v3-primary);font-style:italic;font-size:clamp(1.6rem,3vw,2.5rem);line-height:1.1;color:var(--v3-ink);font-weight:400;margin:0}
  .exp-body{font-family:var(--font-v3-primary);font-size:14px;line-height:1.85;color:var(--v3-muted);margin:0;font-weight:400}
  .exp-rule{border:none;border-top:1px solid var(--v3-rule);margin:0}
  @media(max-width:700px){.exp-header{flex-direction:column;gap:.75rem}.exp-img{aspect-ratio:16/9}.exp-text{grid-template-columns:1fr;gap:1rem}.exp-n{font-size:clamp(3rem,12vw,5rem)}}
</style>

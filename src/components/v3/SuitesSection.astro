---
const suites = [
  { n:'I',   name:'The Cliff Room',    specs:'40 m²  ·  Full sea view  ·  Sea terrace',      body:'The largest of the rooms. One wall is almost entirely glass — the Plovdiv glazing. From the bed you see nothing but water and sky. The bathroom is in the rock face, lined in Provadia limestone. There is no minibar. There is local honey.', image:'/images/room-earth.jpg', alt:'The Cliff Room',    rev:false },
  { n:'II',  name:'The Forest Room',   specs:'36 m²  ·  Forest view  ·  Own balcony',        body:'Set slightly back from the cliff edge, the Forest Room looks into the tree canopy. In summer, light through the leaves moves constantly across the white plaster ceiling. One terrace, one hammock point, one outdoor shower.',              image:'/images/room-water.jpg', alt:'The Forest Room',   rev:true  },
  { n:'III', name:'The Horizon Suite', specs:'67 m²  ·  Sea view  ·  Twelve-metre terrace',  body:'Two rooms, one terrace, the widest sea view on the property. The stone terrace is twelve metres long. In clear weather you can see the silhouette of the Romanian coast. We do not charge by view.',                                         image:'/images/room-fire.jpg',  alt:'The Horizon Suite', rev:false },
  { n:'IV',  name:'The Garden Room',   specs:'31 m²  ·  Garden level  ·  Garden access',     body:'No sea view — by design. If you want to hear nightingales rather than the sea, this is the room. Direct access to the hotel garden. Lowest rate. No compromise on feel, linen, or bathroom.',                                                 image:'/images/room-air.jpg',   alt:'The Garden Room',   rev:true  },
]
---
<section id="suites" class="v3-suites">
  <div class="v3-suites-inner">
    <p class="v3-suites-label">Suites &amp; Rooms</p>
    <h2 class="v3-suites-title" data-aos="fade-up">Four rooms. One standard.</h2>
    <hr class="v3-hr" />
    {suites.map((s, i) => (
      <div>
        <div class={`v3-suite${s.rev ? ' v3-suite-rev' : ''}`} data-aos="fade-up" data-aos-delay={i * 60}>
          <div class="v3-suite-imgwrap">
            <img class="v3-suite-img" src={s.image} alt={s.alt} loading="lazy" />
          </div>
          <div class="v3-suite-textcol">
            <p class="v3-suite-n" aria-hidden="true">{s.n}</p>
            <h3 class="v3-suite-name">{s.name}</h3>
            <p class="v3-suite-specs">{s.specs}</p>
            <p class="v3-suite-body">{s.body}</p>
            <a href="#" class="v3-suite-link">Enquire</a>
          </div>
        </div>
        {i < suites.length - 1 && <hr class="v3-hr" />}
      </div>
    ))}
  </div>
</section>

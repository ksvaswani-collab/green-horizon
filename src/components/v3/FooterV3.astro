---
---
<footer class="foot" role="contentinfo" aria-label="Site footer">
  <div class="foot-wordmark-wrap">
    <a href="/v3/" class="foot-wordmark" aria-label="Green Horizon — home">Green<br>Horizon</a>
  </div>
  <div class="foot-strip">
    <p class="foot-copy">© 2026 Green Horizon · Bulgaria</p>
    <nav class="foot-nav" aria-label="Footer navigation">
      <a href="#story" class="foot-link">Story</a>
      <a href="#elements" class="foot-link">Elements</a>
      <a href="#experiences" class="foot-link">Experiences</a>
      <a href="#register" class="foot-link">Register</a>
    </nav>
    <a href="mailto:hello@greenhorizon.bg" class="foot-email">hello@greenhorizon.bg</a>
  </div>
</footer>
<style>
  .foot{background:var(--v3-bg);border-top:1px solid var(--v3-rule);overflow:hidden}
  .foot-wordmark-wrap{padding:4rem clamp(2rem,6vw,6rem) 2rem}
  .foot-wordmark{display:block;font-family:var(--font-v3-primary);font-style:italic;font-weight:400;font-size:clamp(4.5rem,14vw,14rem);line-height:.9;letter-spacing:-.03em;color:var(--v3-ink);text-decoration:none;transition:opacity .2s ease}
  .foot-wordmark:hover{opacity:.6}
  .foot-strip{display:flex;align-items:center;justify-content:space-between;gap:2rem;flex-wrap:wrap;padding:1.25rem clamp(2rem,6vw,6rem);border-top:1px solid var(--v3-rule)}
  .foot-copy{font-family:var(--font-v3-fine);font-size:11px;letter-spacing:.08em;color:var(--v3-muted);margin:0}
  .foot-nav{display:flex;gap:.25rem;align-items:center;flex-wrap:wrap}
  .foot-link{font-family:var(--font-v3-fine);font-size:11px;letter-spacing:.08em;color:var(--v3-muted);text-decoration:none;padding:.25rem .6rem;transition:color .2s ease}
  .foot-link:hover{color:var(--v3-ink)}
  .foot-email{font-family:var(--font-v3-fine);font-size:11px;letter-spacing:.06em;color:var(--v3-muted);text-decoration:none;transition:color .2s ease}
  .foot-email:hover{color:var(--v3-ink)}
  @media(max-width:640px){.foot-strip{flex-direction:column;align-items:flex-start;gap:1rem}}
</style>

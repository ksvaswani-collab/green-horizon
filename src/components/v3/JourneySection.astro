---
const entries = [
  {
    date: 'April 2024',
    heading: 'Ground is broken. The oak survives.',
    body: 'Excavation began on the fourteenth. The oak at the north-east corner — the one on the earliest cadastral maps — was marked for preservation. The structural engineer redesigned the terrace foundation around it without complaint.',
    src: '/images/build-june-2025.jpg',
    alt: 'Excavation at the Green Horizon cliff site, April 2024',
  },
  {
    date: 'September 2024',
    heading: 'The bones are standing. The view is confirmed.',
    body: 'The concrete frame is complete to roof level. For the first time, we stand in what will be the dining room and look through the framed opening. The view is what we said it would be. There was a collective exhale.',
    src: '/images/build-march-2025.jpg',
    alt: 'Concrete frame of Green Horizon with sea view, September 2024',
  },
  {
    date: 'February 2025',
    heading: 'Stone from Provadia. Glass from Plovdiv.',
    body: 'Interior cladding under way. Local limestone from Provadia quarry — the same material that built the old fortifications at Ovech. Floor-to-ceiling glazing fabricated in Plovdiv. The whole coast will be visible from the bed.',
    src: '/images/build-nov-2024.jpg',
    alt: 'Interior limestone cladding work, February 2025',
  },
]
---

<section id="journey" class="jn" aria-labelledby="jn-hdg">

  <div class="jn-head">
    <p class="jn-overline">The Build · Live from the site</p>
    <h2 class="jn-title" id="jn-hdg">A record<br>of progress.</h2>
  </div>

  <!-- Large counter -->
  <p class="jn-stat" aria-label="Three updates">
    <span class="jn-stat-n">03</span>
    <span class="jn-stat-l">dispatches<br>from the cliff</span>
  </p>

  <div class="jn-entries">
    {entries.map((entry, i) => (
      <article class="jn-card v3-reveal" aria-label={`${entry.date}: ${entry.heading}`}>

        <div class="jn-img-wrap">
          <img class="jn-img" src={entry.src} alt={entry.alt} loading="lazy" />
          <span class="jn-img-date" aria-hidden="true">{entry.date}</span>
        </div>

        <div class="jn-body">
          <p class="jn-date">{entry.date}</p>
          <h3 class="jn-heading">{entry.heading}</h3>
          <p class="jn-text">{entry.body}</p>
        </div>

      </article>
    ))}
  </div>

</section>

<style>
  .jn {
    background: var(--v3-surface);
    padding: 6rem clamp(2rem, 6vw, 6rem);
    border-top: 1px solid var(--v3-rule);
  }

  .jn-head {
    max-width: 80rem;
    margin: 0 auto 1rem;
  }
  .jn-overline {
    font-family: var(--font-v3-fine);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--v3-muted);
    margin: 0 0 1rem;
  }
  .jn-title {
    font-family: var(--font-v3-primary);
    font-style: italic;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    line-height: 1.0;
    color: var(--v3-ink);
    font-weight: 400;
    margin: 0;
    letter-spacing: -0.025em;
  }

  /* Large editorial counter */
  .jn-stat {
    max-width: 80rem;
    margin: 2rem auto 4rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    border-top: 1px solid var(--v3-rule);
    padding-top: 1.5rem;
  }
  .jn-stat-n {
    font-family: var(--font-v3-primary);
    font-style: italic;
    font-size: clamp(3rem, 6vw, 6rem);
    color: rgba(26, 21, 16, 0.12);
    line-height: 1;
    font-weight: 400;
  }
  .jn-stat-l {
    font-family: var(--font-v3-fine);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--v3-muted);
    line-height: 1.6;
  }

  /* Entries: 3-column on desktop */
  .jn-entries {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  /* Each card */
  .jn-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    cursor: default;
  }

  .jn-img-wrap {
    position: relative;
    overflow: hidden;
  }
  .jn-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    filter: grayscale(0.5) brightness(0.9);
    transform: scale(1.04);
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                filter 0.5s ease;
  }
  .jn-card:hover .jn-img {
    transform: scale(1.0);
    filter: grayscale(0.1) brightness(0.97);
  }

  /* Date badge overlaid on image bottom */
  .jn-img-date {
    position: absolute;
    bottom: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-v3-fine);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.7);
    background: rgba(42, 31, 22, 0.55);
    padding: 0.3rem 0.6rem;
    pointer-events: none;
    user-select: none;
  }

  .jn-body { display: flex; flex-direction: column; gap: 0.6rem; }

  .jn-date {
    font-family: var(--font-v3-fine);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--v3-muted);
    margin: 0;
    transition: color 0.25s ease;
  }
  .jn-card:hover .jn-date { color: var(--v3-rust); }

  .jn-heading {
    font-family: var(--font-v3-primary);
    font-style: italic;
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    line-height: 1.2;
    color: var(--v3-ink);
    font-weight: 400;
    margin: 0;
    letter-spacing: -0.01em;
    /* Underline grows on hover */
    background-image: linear-gradient(var(--v3-ink), var(--v3-ink));
    background-size: 0 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    display: inline;
    transition: background-size 0.4s ease;
  }
  .jn-card:hover .jn-heading { background-size: 100% 1px; }

  .jn-text {
    font-family: var(--font-v3-primary);
    font-size: 14px;
    line-height: 1.8;
    color: var(--v3-muted);
    margin: 0;
    font-weight: 400;
    /* Opacity lifts on hover */
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }
  .jn-card:hover .jn-text { opacity: 1; }

  @media (max-width: 900px) { .jn-entries { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .jn-entries { grid-template-columns: 1fr; } }
</style>

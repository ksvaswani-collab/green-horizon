---
const entries = [
  { date:'April 2024',     heading:'Ground is broken. The oak survives.',           body:'Excavation began on the fourteenth. The oak at the north-east corner of the plot was marked for preservation from the start. The structural engineer redesigned the terrace foundation around it without complaint. Work proceeds at the pace the cliff dictates.',           image:'/images/build-june-2025.jpg',  alt:'Excavation at the Green Horizon site' },
  { date:'September 2024', heading:'The bones are standing. The view is confirmed.', body:'The concrete frame is complete to roof level. For the first time we can stand in what will be the dining room and look out through the framed opening. The view is what we said it would be. There was a collective exhale.',                                          image:'/images/build-march-2025.jpg', alt:'Concrete frame with sea view, September 2024' },
  { date:'February 2025',  heading:'Stone from Provadia. Glass from Plovdiv.',       body:'Interior cladding under way — local limestone from the Provadia quarry, the same material that built the fortifications at Ovech. Floor-to-ceiling glazing fabricated in Plovdiv. The whole coast will be visible from the bed.',                                        image:'/images/build-nov-2024.jpg',   alt:'Interior limestone cladding, February 2025' },
]
---
<section id="build" class="v3-build">
  <div class="v3-build-inner">
    <p class="v3-build-overline">The Build · Live from the site</p>
    <h2 class="v3-build-title" data-aos="fade-up">A record of progress.</h2>
    <hr class="v3-hr" />
    <div class="v3-build-grid">
      {entries.map((e, i) => (
        <article class="v3-build-entry" data-aos="fade-up" data-aos-delay={i * 80} aria-label={`${e.date}: ${e.heading}`}>
          <p class="v3-build-date">{e.date}</p>
          <h3 class="v3-build-heading">{e.heading}</h3>
          <img class="v3-build-img" src={e.image} alt={e.alt} loading="lazy" />
          <p class="v3-build-body">{e.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

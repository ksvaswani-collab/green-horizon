---
// JourneySection.astro — V3 "Paper & Grain"
// Newspaper-style section: three journal columns, no timeline borders
// Background: v3-surface

const journalEntries = [
  {
    date: 'April 2024',
    headline: 'Ground is broken. The oak survives.',
    body: 'Excavation began on the fourteenth. The oak at the north-east corner of the plot — the one that appears on the earliest cadastral maps — was marked for preservation from the start. The structural engineer redesigned the terrace foundation around it without complaint. Work proceeds at the pace the cliff dictates.',
    image: '/images/build-june-2025.jpg',
    imageAlt: 'Excavator on clay soil, old oak tree to the right, sea visible in the background, early spring',
  },
  {
    date: 'September 2024',
    headline: 'The bones are standing. The view is confirmed.',
    body: 'The concrete frame of the main structure is complete to roof level. For the first time since we broke ground, we can stand in what will be the dining room and look out through the framed opening where the glass will go. The view is what we said it would be. There was a collective exhale among the family. The structural engineer had told us this would happen. He was right again.',
    image: '/images/build-march-2025.jpg',
    imageAlt: 'Concrete structure skeleton against the sea, formwork still in place, golden afternoon light',
  },
  {
    date: 'February 2025',
    headline: 'Stone from Provadia. Glass from Plovdiv.',
    body: 'The interior cladding is under way. We settled on local limestone from the Provadia quarry — the same material that built the old fortifications at Ovech. The glazing is custom fabricated in Plovdiv, floor-to-ceiling panels that will carry none of the horizontal sightline breaks common in hotel construction. The whole coast will be visible from the bed.',
    image: '/images/build-nov-2024.jpg',
    imageAlt: 'Stone blocks being laid on interior wall, plasterer at work, open window frame showing the cliff edge beyond',
  },
];
---

<section id="build" class="v3-section v3-journey" aria-labelledby="journey-heading">

  <hr class="v3-rule" aria-hidden="true" />

  <!-- Section masthead — newspaper style -->
  <header class="v3-journey__masthead v3-reveal">
    <p class="v3-label" aria-hidden="true">—04—</p>
    <div class="v3-journey__masthead-text">
      <h2 id="journey-heading" class="v3-journey__main-head">The Build</h2>
      <p class="v3-journey__deck">
        <em>Live from the site. The cliff has been rising since April 2024.</em>
      </p>
    </div>
  </header>

  <hr class="v3-rule" aria-hidden="true" />

  <!-- Three newspaper columns -->
  <div class="v3-journey__columns v3-reveal" role="list">
    {journalEntries.map((entry) => (
      <article class="v3-journey__entry" role="listitem" aria-label={`Build journal: ${entry.headline}`}>

        <!-- Byline date -->
        <p class="v3-journey__byline">
          <strong><em>{entry.date}</em></strong>
        </p>

        <!-- Entry headline -->
        <h3 class="v3-journey__entry-head">{entry.headline}</h3>

        <!-- B&W image -->
        <figure class="v3-journey__figure">
          <img
            src={entry.image}
            alt={entry.imageAlt}
            loading="lazy"
            decoding="async"
            class="v3-journey__img"
          />
        </figure>

        <!-- Body text -->
        <p class="v3-journey__entry-body">{entry.body}</p>

      </article>
    ))}
  </div>

  <hr class="v3-rule" aria-hidden="true" />

</section>

<style>
  .v3-journey {
    background-color: var(--v3-surface);
    padding-top: 0;
  }

  /* Masthead */
  .v3-journey__masthead {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 2rem;
    align-items: end;
    padding: 3rem 0 2.5rem;
  }

  .v3-journey__masthead > .v3-label {
    font-size: 13px;
    color: var(--v3-muted);
    padding-bottom: 0.3em;
    text-align: right;
  }

  /* Main headline — large newspaper-style */
  .v3-journey__main-head {
    font-family: var(--font-v3-primary);
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--v3-ink);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  /* Deck / sub-deck */
  .v3-journey__deck {
    font-family: var(--font-v3-primary);
    font-style: italic;
    font-size: 18px;
    color: var(--v3-muted);
    line-height: 1.6;
  }

  /* Three-column layout */
  .v3-journey__columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    column-gap: 3rem;
    padding: 3rem 0 4rem;
    /* Column rules between entries */
    column-rule: 1px solid var(--v3-rule);
  }

  /* Individual journal entry */
  .v3-journey__entry {
    padding: 0;
    break-inside: avoid;
  }

  /* Byline / date */
  .v3-journey__byline {
    font-family: var(--font-v3-primary);
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--v3-muted);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .v3-journey__byline strong {
    font-weight: 400;
  }

  /* Entry headline */
  .v3-journey__entry-head {
    font-family: var(--font-v3-primary);
    font-weight: 400;
    font-size: clamp(1.1rem, 1.8vw, 1.5rem);
    line-height: 1.25;
    color: var(--v3-ink);
    margin-bottom: 1.25rem;
  }

  /* Image */
  .v3-journey__figure {
    margin: 0 0 1.25rem;
  }

  .v3-journey__img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    filter: grayscale(1) contrast(1.1);
  }

  /* Body text */
  .v3-journey__entry-body {
    font-family: var(--font-v3-primary);
    font-size: 16px;
    line-height: 1.85;
    color: var(--v3-ink);
  }

  /* ── Tablet ─────────────────────────────────────────────── */
  @media (max-width: 960px) {
    .v3-journey__columns {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .v3-journey__columns {
      grid-template-columns: 1fr;
      column-gap: 0;
    }

    .v3-journey__entry {
      border-bottom: 1px solid var(--v3-rule);
      padding-bottom: 2.5rem;
      margin-bottom: 2.5rem;
    }

    .v3-journey__entry:last-child {
      border-bottom: none;
      margin-bottom: 0;
    }

    .v3-journey__masthead {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .v3-journey__masthead > .v3-label {
      text-align: left;
    }
  }

  /* ── Lora weight/style system ──────────────────────────── */
  .v3-journey__main-head   { font-weight: 600; font-style: italic; }
  .v3-journey__masthead > .v3-label { font-weight: 600; font-style: normal; }
  .v3-journey__byline      { font-weight: 600; font-style: normal; }
  .v3-journey__entry-head  { font-weight: 600; font-style: italic; }
  .v3-journey__entry-body  { font-weight: 400; font-style: normal; }
</style>

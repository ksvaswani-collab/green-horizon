---
interface Props { lang?: string }
const { lang = 'en' } = Astro.props
import en from '../i18n/en.json'
import nl from '../i18n/nl.json'
import bg from '../i18n/bg.json'
const translations: Record<string, typeof en> = { en, nl, bg }
const t = translations[lang] ?? en
const lp = `/${lang}`
---
<nav id="site-nav" style="position:fixed;top:0;left:0;right:0;z-index:50;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between;">
  <a href={`${lp}/`} style="font-family:var(--font-display);font-weight:300;font-size:1.1rem;color:var(--color-limestone);text-decoration:none;letter-spacing:-0.01em;">HORIZON</a>
  <ul class="desktop-links" style="display:flex;gap:2.5rem;list-style:none;font-family:var(--font-mono);font-size:11px;color:var(--color-seafoam);letter-spacing:0.15em;text-transform:uppercase;">
    <li><a href={`${lp}/#experiences`} class="nl">{t.nav.experiences}</a></li>
    <li><a href={`${lp}/#story`}       class="nl">{t.nav.story}</a></li>
    <li><a href={`${lp}/#rooms`}       class="nl">{t.nav.rooms}</a></li>
    <li><a href={`${lp}/#contact`}     class="nl">{t.nav.contact}</a></li>
  </ul>
  <div style="display:flex;align-items:center;gap:2rem;">
    <span style="font-family:var(--font-mono);font-size:11px;color:var(--color-seafoam);letter-spacing:0.15em;">
      <a href="/en/" class={`ll${lang==='en'?' la':''}`}>EN</a> /
      <a href="/nl/" class={`ll${lang==='nl'?' la':''}`}>NL</a> /
      <a href="/bg/" class={`ll${lang==='bg'?' la':''}`}>BG</a>
    </span>
    <a href={`${lp}/#contact`} style="font-family:var(--font-mono);font-size:11px;color:var(--color-copper);text-decoration:none;letter-spacing:0.15em;text-transform:uppercase;">{t.nav.registerInterest}</a>
    <button id="hamburger" aria-label="Open menu" aria-expanded="false" class="hb" style="display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;">
      <span class="bar" style="display:block;width:24px;height:1px;background:var(--color-limestone);"></span>
      <span class="bar" style="display:block;width:24px;height:1px;background:var(--color-limestone);"></span>
      <span class="bar" style="display:block;width:16px;height:1px;background:var(--color-limestone);"></span>
    </button>
  </div>
</nav>
<div id="mobile-menu" role="dialog" aria-modal="true" style="position:fixed;inset:0;z-index:49;background:var(--color-midnight);display:flex;flex-direction:column;justify-content:center;padding:6rem 2rem 3rem;transform:translateY(-100%);transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);pointer-events:none;">
  <ul style="list-style:none;display:flex;flex-direction:column;gap:2rem;">
    <li><a href={`${lp}/#experiences`} class="mml" style="font-family:var(--font-display);font-weight:300;font-size:clamp(2rem,8vw,4rem);color:var(--color-limestone);text-decoration:none;">{t.nav.experiences}</a></li>
    <li><a href={`${lp}/#story`}       class="mml" style="font-family:var(--font-display);font-weight:300;font-size:clamp(2rem,8vw,4rem);color:var(--color-limestone);text-decoration:none;">{t.nav.story}</a></li>
    <li><a href={`${lp}/#rooms`}       class="mml" style="font-family:var(--font-display);font-weight:300;font-size:clamp(2rem,8vw,4rem);color:var(--color-limestone);text-decoration:none;">{t.nav.rooms}</a></li>
    <li><a href={`${lp}/#contact`}     class="mml" style="font-family:var(--font-display);font-weight:300;font-size:clamp(2rem,8vw,4rem);color:var(--color-copper);text-decoration:none;">{t.nav.registerInterest}</a></li>
  </ul>
  <div style="margin-top:auto;font-family:var(--font-mono);font-size:11px;color:var(--color-seafoam);letter-spacing:0.15em;display:flex;gap:1.5rem;">
    <a href="/en/" style="color:inherit;text-decoration:none;">EN</a>
    <a href="/nl/" style="color:inherit;text-decoration:none;">NL</a>
    <a href="/bg/" style="color:inherit;text-decoration:none;">BG</a>
  </div>
</div>
<style>
  .nl,.ll{color:inherit;text-decoration:none;transition:color 0.2s ease;}
  .nl:hover,.ll:hover,.la{color:var(--color-limestone);}
  .la{text-decoration:underline;text-underline-offset:3px;}
  @media(max-width:768px){.desktop-links{display:none!important;}.hb{display:flex!important;}}
</style>
<script>
  const g=(window as any).gsap,ST=(window as any).ScrollTrigger
  if(g&&ST){ST.create({start:80,onEnter:()=>g.to('#site-nav',{backgroundColor:'#1A2420',duration:0.4,ease:'power2.out'}),onLeaveBack:()=>g.to('#site-nav',{backgroundColor:'transparent',duration:0.4})})}
  else{const n=document.getElementById('site-nav');window.addEventListener('scroll',()=>{if(n)n.style.backgroundColor=window.scrollY>80?'#1A2420':'transparent'},{passive:true})}
  const btn=document.getElementById('hamburger'),menu=document.getElementById('mobile-menu')
  let open=false
  function toggle(v:boolean){open=v;if(!btn||!menu)return;btn.setAttribute('aria-expanded',String(v));menu.style.transform=v?'translateY(0)':'translateY(-100%)';menu.style.pointerEvents=v?'auto':'none';document.body.style.overflow=v?'hidden':'';}
  btn?.addEventListener('click',()=>toggle(!open))
  document.querySelectorAll('.mml').forEach(l=>l.addEventListener('click',()=>toggle(false)))
  document.addEventListener('keydown',(e)=>{if(e.key==='Escape'&&open)toggle(false)})
</script>

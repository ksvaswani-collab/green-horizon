---
interface Props { lang?: string }
const { lang = 'en' } = Astro.props
import en from '../i18n/en.json'
import nl from '../i18n/nl.json'
import bg from '../i18n/bg.json'
const translations: Record<string, typeof en> = { en, nl, bg }
const t = translations[lang] ?? en
const lp = `/${lang}`

/* Shared pill styling — same bg, same border, same radius — just separate nodes */
---

<header
  id="site-header"
  aria-label="Site header"
  style="
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    pointer-events: none;  /* let clicks through the gap between pills */
  "
>

  <!-- PILL 1 — Wordmark -->
  <a
    href={`${lp}/`}
    class="nav-pill"
    aria-label="Green Horizon — Home"
    style="
      pointer-events: auto;
      display: flex;
      align-items: center;
      padding: 0.6rem 1.25rem;
      font-family: var(--font-display);
      font-weight: 300;
      font-size: 1rem;
      color: var(--color-midnight);
      text-decoration: none;
      letter-spacing: -0.01em;
      white-space: nowrap;
    "
  >
    HORIZON
  </a>

  <!-- PILL 2 — Nav links (desktop only) -->
  <nav
    class="nav-pill nav-links-pill"
    aria-label="Main navigation"
    style="
      pointer-events: auto;
      display: flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.6rem 1rem;
    "
  >
    <a href={`${lp}/#experiences`} class="nav-link">{t.nav.experiences}</a>
    <span class="nav-sep" aria-hidden="true">·</span>
    <a href={`${lp}/#story`}       class="nav-link">{t.nav.story}</a>
    <span class="nav-sep" aria-hidden="true">·</span>
    <a href={`${lp}/#rooms`}       class="nav-link">{t.nav.rooms}</a>
    <span class="nav-sep" aria-hidden="true">·</span>
    <a href={`${lp}/#contact`}     class="nav-link">{t.nav.contact}</a>
  </nav>

  <!-- PILL 3 — Lang switcher + CTA + mobile hamburger -->
  <div
    class="nav-pill"
    style="
      pointer-events: auto;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.6rem 1.25rem;
    "
  >
    <!-- Language switcher -->
    <span class="lang-group" style="display:flex;align-items:center;gap:0.5rem;font-family:var(--font-mono);font-size:10px;letter-spacing:0.15em;">
      <a href="/en/" class={`ll${lang==='en'?' la':''}`}>EN</a>
      <span style="color:var(--color-muted);opacity:0.4;">/</span>
      <a href="/nl/" class={`ll${lang==='nl'?' la':''}`}>NL</a>
      <span style="color:var(--color-muted);opacity:0.4;">/</span>
      <a href="/bg/" class={`ll${lang==='bg'?' la':''}`}>BG</a>
    </span>

    <!-- CTA — hidden on mobile -->
    <a href={`${lp}/#contact`} class="nav-cta desktop-cta">
      {t.nav.registerInterest}
    </a>

    <!-- Hamburger — mobile only -->
    <button
      id="hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      class="hb"
      style="display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:2px;"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar" style="width:16px;"></span>
    </button>
  </div>
</header>

<!-- Mobile fullscreen overlay -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  style="
    position:fixed;inset:0;z-index:49;
    background:var(--color-linen);
    display:flex;flex-direction:column;justify-content:center;
    padding:6rem 2rem 3rem;
    transform:translateY(-100%);
    transition:transform 0.5s cubic-bezier(0.16,1,0.3,1);
    pointer-events:none;
  "
>
  <ul style="list-style:none;display:flex;flex-direction:column;gap:2rem;">
    <li><a href={`${lp}/#experiences`} class="mml">{t.nav.experiences}</a></li>
    <li><a href={`${lp}/#story`}       class="mml">{t.nav.story}</a></li>
    <li><a href={`${lp}/#rooms`}       class="mml">{t.nav.rooms}</a></li>
    <li><a href={`${lp}/#contact`}     class="mml" style="color:var(--color-copper)!important;">{t.nav.registerInterest}</a></li>
  </ul>
  <div style="margin-top:auto;font-family:var(--font-mono);font-size:10px;color:var(--color-muted);letter-spacing:0.15em;display:flex;gap:1.5rem;">
    <a href="/en/" style="color:inherit;text-decoration:none;">EN</a>
    <a href="/nl/" style="color:inherit;text-decoration:none;">NL</a>
    <a href="/bg/" style="color:inherit;text-decoration:none;">BG</a>
  </div>
</div>

<style>
  /* Shared pill appearance */
  .nav-pill {
    background: rgba(240, 237, 230, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(13, 17, 23, 0.08);
    border-radius: 100px;
    transition: background 0.35s ease, border-color 0.35s ease;
  }

  /* Scrolled: pills become slightly more opaque */
  .nav-pill.scrolled {
    background: rgba(240, 237, 230, 0.97);
    border-color: rgba(13, 17, 23, 0.12);
  }

  /* Nav links */
  .nav-link {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-midnight);
    background: rgba(13, 17, 23, 0.06);
  }

  .nav-sep {
    font-size: 10px;
    color: var(--color-muted);
    opacity: 0.35;
    pointer-events: none;
    user-select: none;
  }

  /* Language links */
  .ll {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ll:hover, .la {
    color: var(--color-midnight);
  }
  .la {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Register CTA */
  .nav-cta {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-copper);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .nav-cta:hover { opacity: 0.7; }

  /* Hamburger bars */
  .bar {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--color-midnight);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Mobile link style */
  .mml {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 8vw, 4rem);
    color: var(--color-midnight);
    text-decoration: none;
    display: block;
  }

  /* Responsive: hide nav links pill on mobile, show hamburger */
  @media (max-width: 768px) {
    .nav-links-pill { display: none !important; }
    .desktop-cta    { display: none !important; }
    .hb             { display: flex !important; }
  }
</style>

<script>
  // Scrolled state — add class to all pills
  const pills = document.querySelectorAll('.nav-pill')
  const onScroll = () => {
    const scrolled = window.scrollY > 60
    pills.forEach(p => p.classList.toggle('scrolled', scrolled))
  }
  window.addEventListener('scroll', onScroll, { passive: true })
  onScroll()

  // Mobile menu
  const btn  = document.getElementById('hamburger')
  const menu = document.getElementById('mobile-menu')
  let open = false

  function toggle(v: boolean) {
    open = v
    btn?.setAttribute('aria-expanded', String(v))
    if (menu) {
      menu.style.transform  = v ? 'translateY(0)' : 'translateY(-100%)'
      menu.style.pointerEvents = v ? 'auto' : 'none'
    }
    document.body.style.overflow = v ? 'hidden' : ''
  }

  btn?.addEventListener('click', () => toggle(!open))
  document.querySelectorAll('.mml').forEach(l => l.addEventListener('click', () => toggle(false)))
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && open) toggle(false) })
</script>

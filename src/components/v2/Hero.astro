---
// V2 Hero — typographic split. Left: pure dark with giant type. Right: contained image panel.
// Radically different from V1 (full-bleed image, text bottom-left).
---

<section id="v2-hero" aria-label="Hero — Green Horizon">

  <!-- Left: pure typographic dark panel -->
  <div class="hero-left">

    <!-- Vertical coordinate label — design accent -->
    <span class="hero-coord" aria-hidden="true">42°N 27°E</span>

    <!-- Ghost background numeral -->
    <span class="hero-ghost" aria-hidden="true">01</span>

    <div class="hero-text-block">
      <h1 class="hero-headline" aria-label="The Horizon Calls.">
        <span class="hero-line" id="hero-line-1" aria-hidden="true"></span>
        <span class="hero-line" id="hero-line-2" aria-hidden="true"></span>
        <span class="hero-line hero-line-bright" id="hero-line-3" aria-hidden="true"></span>
      </h1>

      <p class="hero-sub" id="hero-sub">
        A cliff above the Black Sea.<br>Between ancient forest and open water.
      </p>

      <div class="hero-actions" id="hero-actions">
        <a href="#story"    class="v2-btn v2-btn-primary"  data-magnetic>Discover the story</a>
        <a href="#register" class="v2-btn v2-btn-outline"  data-magnetic>Register interest</a>
      </div>
    </div>

    <!-- Thin bottom rule that draws in on load -->
    <div class="hero-rule" id="hero-rule" aria-hidden="true"></div>
  </div>

  <!-- Right: contained image panel — NOT full-bleed, deliberately framed -->
  <div class="hero-right" aria-hidden="true">
    <div class="hero-frame">
      <img
        src="/images/hero.jpg"
        alt=""
        class="hero-img"
        fetchpriority="high"
        loading="eager"
      />
      <!-- Thin copper border overlay -->
      <div class="hero-frame-border"></div>
    </div>
    <!-- Caption beside the frame -->
    <p class="hero-caption">Strandzha / Black Sea coast</p>
  </div>

</section>

<!-- Marquee strip below hero -->
<div class="v2-marquee-strip" aria-hidden="true" role="presentation">
  <div class="v2-marquee-inner" id="v2-marquee-text">
    EARTH&nbsp;&nbsp;·&nbsp;&nbsp;WATER&nbsp;&nbsp;·&nbsp;&nbsp;FIRE&nbsp;&nbsp;·&nbsp;&nbsp;AIR&nbsp;&nbsp;·&nbsp;&nbsp;BLACK SEA&nbsp;&nbsp;·&nbsp;&nbsp;BULGARIA&nbsp;&nbsp;·&nbsp;&nbsp;42°N&nbsp;&nbsp;·&nbsp;&nbsp;27°E&nbsp;&nbsp;·&nbsp;&nbsp;OPENING 2026&nbsp;&nbsp;·&nbsp;&nbsp;
    EARTH&nbsp;&nbsp;·&nbsp;&nbsp;WATER&nbsp;&nbsp;·&nbsp;&nbsp;FIRE&nbsp;&nbsp;·&nbsp;&nbsp;AIR&nbsp;&nbsp;·&nbsp;&nbsp;BLACK SEA&nbsp;&nbsp;·&nbsp;&nbsp;BULGARIA&nbsp;&nbsp;·&nbsp;&nbsp;42°N&nbsp;&nbsp;·&nbsp;&nbsp;27°E&nbsp;&nbsp;·&nbsp;&nbsp;OPENING 2026&nbsp;&nbsp;·&nbsp;&nbsp;
  </div>
</div>

<style>
  /* ── Section layout: horizontal split ── */
  #v2-hero {
    display: grid;
    grid-template-columns: 55fr 45fr;
    min-height: 100svh;
    background: #060A08;
    overflow: hidden;
  }

  /* ── LEFT panel ── */
  .hero-left {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(5rem, 8vh, 7rem) clamp(2rem, 5vw, 5rem) clamp(4rem, 6vh, 6rem);
    overflow: hidden;
  }

  /* Ghost numeral background */
  .hero-ghost {
    position: absolute;
    top: 50%;
    left: -0.1em;
    transform: translateY(-60%);
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(16rem, 28vw, 28rem);
    line-height: 1;
    color: rgba(234, 230, 222, 0.025);
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
  }

  /* Vertical coordinate */
  .hero-coord {
    position: absolute;
    top: 50%;
    left: 1.25rem;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center center;
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 0.18em;
    color: rgba(168, 213, 194, 0.45);
    white-space: nowrap;
  }

  .hero-text-block {
    position: relative;
    z-index: 1;
    padding-left: 1.5rem;
  }

  /* ── Headline ── */
  .hero-headline {
    display: block;
    margin-bottom: 2rem;
  }

  .hero-line {
    display: block;
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(48px, 8vw, 120px);
    letter-spacing: -0.04em;
    line-height: 0.92;
    color: #EAE6DE;
  }

  .hero-line-bright {
    color: #A8D5C2;
  }

  .hero-line :global(.char) {
    display: inline-block;
    will-change: transform, opacity;
  }

  /* ── Subtitle ── */
  .hero-sub {
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 400;
    font-size: 15px;
    line-height: 1.8;
    color: #7A8C84;
    margin-bottom: 2.5rem;
    padding-left: 1.5rem;
    border-left: 1px solid rgba(168, 213, 194, 0.25);
    opacity: 0;
  }

  /* ── Buttons ── */
  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    opacity: 0;
  }

  .v2-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    text-decoration: none;
    cursor: none;
    border: 1px solid transparent;
    border-radius: 16px;
    white-space: nowrap;
    transition: background 0.25s ease, border-color 0.25s ease;
    will-change: transform;
  }

  .v2-btn-primary  { background: #2B4A3C; color: #EAE6DE; border-color: #2B4A3C; }
  .v2-btn-primary:hover  { background: #3a6352; border-color: #3a6352; }
  .v2-btn-outline  { background: transparent; color: #A8D5C2; border-color: rgba(168,213,194,0.5); }
  .v2-btn-outline:hover  { background: rgba(168,213,194,0.07); border-color: #A8D5C2; }

  :focus-visible { outline: 2px solid #A8D5C2; outline-offset: 4px; }

  /* Animated bottom rule */
  .hero-rule {
    position: absolute;
    bottom: 0; left: 0;
    height: 1px;
    width: 0;
    background: rgba(234,230,222,0.12);
  }

  /* ── RIGHT panel ── */
  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 3rem 4rem 1rem;
    gap: 1rem;
  }

  /* The "framed photograph" — deliberately not full-bleed */
  .hero-frame {
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 3/4;
    overflow: hidden;
    /* Slight clockwise tilt — graphic tension */
    transform: rotate(1.5deg);
    opacity: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    filter: saturate(0.82) contrast(1.08);
  }

  /* Thin copper inset border overlay */
  .hero-frame-border {
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(196, 135, 106, 0.35);
    pointer-events: none;
  }

  .hero-caption {
    font-family: 'DM Serif Display', Georgia, serif;
    font-style: italic;
    font-size: 12px;
    color: rgba(234, 230, 222, 0.3);
    letter-spacing: 0.05em;
    align-self: flex-end;
    margin-right: 1rem;
    opacity: 0;
    transform: rotate(1.5deg);
  }

  /* ── Marquee ── */
  .v2-marquee-strip {
    background: #060A08;
    border-top: 1px solid rgba(234,230,222,0.08);
    border-bottom: 1px solid rgba(234,230,222,0.08);
    overflow: hidden;
    white-space: nowrap;
    padding: 0.875rem 0;
    user-select: none;
  }

  .v2-marquee-inner {
    display: inline-block;
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: #7A8C84;
    will-change: transform;
  }

  /* ── Mobile: stack vertically ── */
  @media (max-width: 768px) {
    #v2-hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
    }
    .hero-right {
      padding: 0 1.5rem 3rem;
      order: -1; /* image above on mobile */
    }
    .hero-frame {
      max-width: 100%;
      aspect-ratio: 16/9;
      transform: none;
    }
    .hero-caption { transform: none; }
    .hero-left { padding: 3rem 1.5rem; }
    .hero-coord { display: none; }
    .hero-line { font-size: clamp(40px, 10vw, 72px); }
    .hero-actions { flex-direction: column; }
    .v2-btn { width: 100%; justify-content: center; cursor: pointer; }
  }
</style>

<script>
  (function () {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // ── Split headline into char spans ──
    const lineData = [
      { id: 'hero-line-1', text: 'THE' },
      { id: 'hero-line-2', text: 'HORIZON' },
      { id: 'hero-line-3', text: 'CALLS.' },
    ]

    const allChars: HTMLElement[] = []

    lineData.forEach(({ id, text }) => {
      const el = document.getElementById(id)
      if (!el) return
      el.innerHTML = ''
      text.split('').forEach(ch => {
        const span = document.createElement('span')
        span.className = 'char'
        span.textContent = ch
        el.appendChild(span)
        allChars.push(span)
      })
    })

    const subEl    = document.getElementById('hero-sub')
    const actEl    = document.getElementById('hero-actions')
    const frameEl  = document.querySelector<HTMLElement>('.hero-frame')
    const capEl    = document.querySelector<HTMLElement>('.hero-caption')
    const ruleEl   = document.getElementById('hero-rule')

    const initAnim = () => {
      const g = (window as any).gsap
      if (!g) return

      if (prefersReduced) {
        allChars.forEach(c => c.style.opacity = '1')
        ;[subEl, actEl, frameEl, capEl].forEach(el => { if (el) el.style.opacity = '1' })
        if (ruleEl) ruleEl.style.width = '100%'
        return
      }

      g.set(allChars,             { y: -50, opacity: 0 })
      g.set([subEl, actEl],       { opacity: 0, y: 16 })
      g.set([frameEl, capEl],     { opacity: 0, x: 30 })
      g.set(ruleEl,               { width: 0 })

      const tl = g.timeline({ delay: 0.15 })

      // Frame slides in from right first — image before text creates tension
      tl.to(frameEl, { opacity: 1, x: 0, duration: 1.0, ease: 'power3.out' })

      // Chars cascade down
      tl.to(allChars, {
        y: 0, opacity: 1,
        duration: 0.8, ease: 'power4.out', stagger: 0.025,
      }, '-=0.7')

      // Sub + actions
      tl.to(subEl,  { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, '-=0.2')
      tl.to(actEl,  { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' }, '-=0.35')

      // Rule draws across
      tl.to(ruleEl, { width: '100%', duration: 0.8, ease: 'power2.inOut' }, '-=0.6')

      // Caption appears
      tl.to(capEl,  { opacity: 1, duration: 0.5, ease: 'power2.out' }, '-=0.4')
    }

    if ((window as any).gsap) initAnim()
    else window.addEventListener('load', initAnim)

    // ── Magnetic buttons ──
    if (window.matchMedia('(pointer: fine)').matches) {
      document.querySelectorAll('[data-magnetic]').forEach(btn => {
        const el = btn as HTMLElement
        el.addEventListener('mousemove', (e: Event) => {
          const g = (window as any).gsap
          if (!g) return
          const me = e as MouseEvent
          const r = el.getBoundingClientRect()
          g.to(el, { x: (me.clientX - r.left - r.width/2) * 0.3, y: (me.clientY - r.top - r.height/2) * 0.3, duration: 0.4, ease: 'power3.out' })
        })
        el.addEventListener('mouseleave', () => {
          const g = (window as any).gsap
          if (g) g.to(el, { x: 0, y: 0, duration: 0.5, ease: 'elastic.out(1,0.5)' })
        })
      })
    }

    // ── Marquee ──
    const marqueeEl = document.getElementById('v2-marquee-text')
    if (marqueeEl && !prefersReduced) {
      const startMarquee = () => {
        const g = (window as any).gsap
        if (!g) return
        const w = marqueeEl.scrollWidth / 2
        g.set(marqueeEl, { x: 0 })
        g.to(marqueeEl, { x: -w, duration: 28, ease: 'none', repeat: -1 })
      }
      if ((window as any).gsap) startMarquee()
      else window.addEventListener('load', startMarquee)
    }
  })()
</script>

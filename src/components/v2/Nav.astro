---
// V2 Nav — The Bend Club reference.
// Wordmark left · centre links (dot-separated) · CTA right.
// No pills, no borders. Transparent. Slides down after hero animation completes.
---
<header id="v2-nav" role="banner">
  <a href="#main" class="v2-nav-skip">Skip to main content</a>

  <nav aria-label="Primary navigation">

    <!-- Left: wordmark -->
    <a href="/v2/" class="v2-nav-wordmark" aria-label="Green Horizon — home">
      <span class="wm-italic">Green</span> Horizon
    </a>

    <!-- Centre: links separated by · -->
    <ul class="v2-nav-links" role="list">
      <li><a href="#story"      class="v2-nl">The story</a></li>
      <li class="v2-nl-sep" aria-hidden="true">·</li>
      <li><a href="#elements"   class="v2-nl">Elements</a></li>
      <li class="v2-nl-sep" aria-hidden="true">·</li>
      <li><a href="#rooms"      class="v2-nl">Rooms</a></li>
      <li class="v2-nl-sep" aria-hidden="true">·</li>
      <li><a href="#experiences"class="v2-nl">Experiences</a></li>
    </ul>

    <!-- Right: single text CTA -->
    <a href="#register" class="v2-nav-cta">Register interest</a>

  </nav>
</header>

<style>
  #v2-nav{
    position:fixed;top:0;left:0;right:0;z-index:900;
    padding:1.75rem clamp(1.5rem,4vw,4rem);
    /* Starts invisible — slides down in JS after hero animation */
    opacity:0;transform:translateY(-12px);
    transition:background .4s ease;
  }
  #v2-nav.is-scrolled{
    background:rgba(14,20,16,.88);
    backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
    border-bottom:1px solid rgba(234,230,222,.07);
  }

  nav{
    display:flex;align-items:center;justify-content:space-between;gap:2rem;
  }

  /* Wordmark — "Green" italic serif + "Horizon" bold */
  .v2-nav-wordmark{
    font-family:'Manrope',system-ui,sans-serif;
    font-weight:700;font-size:1rem;letter-spacing:-.01em;
    color:#EAE6DE;text-decoration:none;
    display:flex;align-items:baseline;gap:.2rem;
    flex-shrink:0;
    transition:opacity .2s ease;
  }
  .v2-nav-wordmark:hover{opacity:.7;}
  .wm-italic{
    font-family:'DM Serif Display',Georgia,serif;
    font-style:italic;font-weight:400;
    font-size:1.1rem;
  }

  /* Centre nav links */
  .v2-nav-links{
    list-style:none;display:flex;align-items:center;gap:.5rem;
    padding:0;margin:0;
  }
  .v2-nl{
    font-family:'Manrope',system-ui,sans-serif;font-size:13px;font-weight:500;
    color:rgba(234,230,222,.5);text-decoration:none;
    transition:color .2s ease;
    padding:.25rem .35rem;
  }
  .v2-nl:hover{color:#EAE6DE;}
  .v2-nl-sep{
    color:rgba(234,230,222,.2);font-size:13px;
    pointer-events:none;user-select:none;
  }

  /* Right CTA — just a text link with underline on hover */
  .v2-nav-cta{
    font-family:'Manrope',system-ui,sans-serif;font-size:13px;font-weight:500;
    color:#A8D5C2;text-decoration:none;
    border-bottom:1px solid transparent;padding-bottom:1px;
    transition:border-color .2s ease;
    flex-shrink:0;
  }
  .v2-nav-cta:hover{border-color:#A8D5C2;}

  /* Skip link */
  .v2-nav-skip{position:absolute;top:-100%;left:50%;transform:translateX(-50%);z-index:10000;background:#A8D5C2;color:#111816;padding:.75rem 1.5rem;border-radius:0 0 12px 12px;font-family:'Manrope',system-ui,sans-serif;font-weight:700;font-size:14px;text-decoration:none;}
  .v2-nav-skip:focus{top:0;}
  :focus-visible{outline:3px solid #A8D5C2;outline-offset:3px;border-radius:4px;}

  /* Mobile: hide centre links */
  @media(max-width:768px){.v2-nav-links{display:none;}}
</style>

<script>
  const nav = document.getElementById('v2-nav')

  // Slide nav in after hero animation completes (~3.4s)
  const showNav = () => {
    const g = (window as any).gsap
    if(g && nav){
      g.to(nav,{ opacity:1, y:0, duration:.7, ease:'power3.out', delay:3.4 })
    } else if(nav){
      setTimeout(()=>{ nav.style.opacity='1'; nav.style.transform='none' }, 3400)
    }
  }
  if((window as any).gsap) showNav()
  else window.addEventListener('load', showNav)

  // Scroll: add bg
  if(nav){
    window.addEventListener('scroll',()=>{
      nav.classList.toggle('is-scrolled', window.scrollY > 40)
    },{ passive:true })
  }
</script>

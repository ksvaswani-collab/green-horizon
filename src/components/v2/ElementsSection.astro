---
// V2 ElementsSection — GSAP carousel with absolute-positioned cards.
// Each card is position:absolute; left:50%. GSAP uses xPercent:-50 + x-offset.
// No container-level translate needed — zero ghost card / measurement issues.
const elements = [
  { id:'earth', number:'01', name:'Earth',
    body:'Strandzha oak, ancient limestone, the smell of forest floor after rain.',
    sub:'The ancient volcanic cliff — forest floor to the edge.',
    image:'/images/earth.jpg', alt:'Dense Strandzha ancient forest, dark and layered',
    bg:'#141f14', accent:'#B8956A', cta:'Explore Earth' },
  { id:'water', number:'02', name:'Water',
    body:'The Black Sea does not perform. It waits.',
    sub:'Twelve nations meet at its floor.',
    image:'/images/water.jpg', alt:'Black Sea surface at calm morning, dark and still',
    bg:'#0e1a1f', accent:'#6AB8C8', cta:'Explore Water' },
  { id:'fire', number:'03', name:'Fire',
    body:'Copper light. The hour before it all goes dark.',
    sub:'Dinner as the longest part of the day.',
    image:'/images/fire.jpg', alt:'Golden sunset over Bulgarian Black Sea coast',
    bg:'#1f1209', accent:'#C8846A', cta:'Explore Fire' },
  { id:'air', number:'04', name:'Air',
    body:'On the cliff edge, wind decides the day.',
    sub:'Open sky. Space that opens your chest.',
    image:'/images/air.jpg', alt:'Open sky above sea cliffs, wide horizon',
    bg:'#0e1318', accent:'#6AC8A8', cta:'Explore Air' },
]
const GAP_REM = 1.5  // matches CSS gap
---

<section id="elements" aria-labelledby="elements-hdg">

  <!-- Header -->
  <header class="el-head">
    <h2 id="elements-hdg" class="el-title">Four ways to feel alive.</h2>
    <div class="el-nav" role="group" aria-label="Element navigation">
      <button id="el-prev" class="el-arrow" aria-label="Previous element">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M11 13.5L6.5 9L11 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="el-dots" role="tablist" id="el-dots">
        {elements.map((el,i)=>(
          <button class={`el-dot${i===0?' el-dot--active':''}`} role="tab"
            aria-selected={i===0} aria-label={el.name} data-index={i}></button>
        ))}
      </div>
      <button id="el-next" class="el-arrow" aria-label="Next element">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M7 4.5L11.5 9L7 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </header>

  <!--
    Deck container: relative + overflow visible.
    Height matches the tallest card (~card-width * 2/3 image + body).
    Cards are position:absolute inside, GSAP positions them.
  -->
  <div class="el-deck" id="el-deck" aria-live="polite">
    {elements.map((el,i)=>(
      <article
        class="el-card"
        id={`el-card-${i}`}
        data-index={i}
        style={`background:${el.bg};--accent:${el.accent};`}
        aria-label={`${el.number} of 04 — ${el.name}: ${el.body}`}
        aria-hidden={i!==0}
      >
        <div class="el-img-wrap">
          <img src={el.image} alt={el.alt} class="el-img" loading={i===0?'eager':'lazy'} />
          <div class="el-img-scrim" aria-hidden="true"></div>
        </div>
        <div class="el-card-inner">
          <div class="el-card-meta">
            <span class="el-num" style={`color:${el.accent}`}>{el.number}</span>
            <span class="el-total">/ 04</span>
          </div>
          <h3 class="el-name">{el.name}</h3>
          <p  class="el-body">{el.body}</p>
          <p  class="el-sub">{el.sub}</p>
          <a href="#register" class="el-cta" style={`border-color:${el.accent};color:${el.accent};`}>
            {el.cta} →
          </a>
        </div>
      </article>
    ))}
  </div>

</section>

<style>
  /* Card width — single source of truth */
  #elements { --cw: clamp(240px, 38vw, 520px); --cg: 1.5rem; }
  @media (max-width: 1024px) { #elements { --cw: clamp(240px, 48vw, 440px); } }
  @media (max-width:  640px) { #elements { --cw: clamp(220px, 78vw, 300px); } }

  #elements { background: #1F1D18; padding: 4rem 0 6rem; }

  /* ── Header ── */
  .el-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
    padding: 0 clamp(1.5rem,4vw,4rem) 2.5rem;
  }
  .el-title {
    font-family: 'Manrope', system-ui, sans-serif; font-weight: 900;
    font-size: clamp(1.5rem,3vw,2.5rem); letter-spacing: -.03em;
    color: #EAE6DE; margin: 0; flex: 1;
  }
  .el-nav  { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
  .el-arrow {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(234,230,222,.06); border: 1px solid rgba(234,230,222,.12);
    border-radius: 50%; color: rgba(234,230,222,.7); cursor: pointer;
    transition: background .2s, border-color .2s, color .2s;
  }
  .el-arrow:hover   { background: rgba(234,230,222,.12); color: #EAE6DE; border-color: rgba(234,230,222,.25); }
  .el-arrow:disabled{ opacity: .3; cursor: not-allowed; }
  .el-arrow:focus-visible { outline: 3px solid #A8D5C2; outline-offset: 3px; }
  .el-dots { display: flex; gap: .5rem; align-items: center; }
  .el-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(234,230,222,.2); border: none; cursor: pointer; padding: 0;
    transition: background .3s, transform .3s;
  }
  .el-dot--active { background: var(--accent, #A8D5C2); transform: scale(1.3); }
  .el-dot:focus-visible { outline: 2px solid #A8D5C2; outline-offset: 3px; border-radius: 50%; }

  /* ── Deck container ──
     Relative + explicit height. Overflow visible so side cards peek.
     Height = card-width * image-ratio(2/3) + card-body(~155px). ── */
  .el-deck {
    position: relative;
    width: 100%;
    /* Height must match tallest card — approximate from CSS vars */
    height: calc(var(--cw) * (2/3) + 175px);
    overflow: visible;
  }

  /* ── Cards — all absolute, centered at left:50% ──
     GSAP sets xPercent:-50 + x-offset. No double translate. ── */
  .el-card {
    position: absolute;
    top: 0;
    left: 50%;           /* base: left edge at viewport center */
    /* GSAP will set: xPercent:-50, x:(i-active)*(cardW+gap) */
    /* Initial CSS (before JS): stack all at center but hidden */
    opacity: 0;
    width: var(--cw);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(234,230,222,.06);
    will-change: transform, opacity;
  }

  /* ── Card contents ── */
  .el-img-wrap { position: relative; width: 100%; aspect-ratio: 3/2; overflow: hidden; }
  .el-img {
    width: 100%; height: 100%; object-fit: cover;
    filter: saturate(.72) contrast(1.06) brightness(.85);
    transition: filter .5s, transform .6s;
  }
  .el-img-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 55%, rgba(0,0,0,.55) 100%);
  }
  .el-card-inner { padding: 1.1rem 1.4rem 1.5rem; display: flex; flex-direction: column; gap: .4rem; }
  .el-card-meta  { display: flex; align-items: baseline; gap: .5rem; margin-bottom: .2rem; }
  .el-num  { font-family: 'Lora', Georgia, serif; font-style: italic; font-size: .9rem; }
  .el-total{ font-family: 'Manrope', system-ui, sans-serif; font-size: 10px; letter-spacing: .1em; color: rgba(234,230,222,.25); }
  .el-name {
    font-family: 'Manrope', system-ui, sans-serif; font-weight: 900;
    font-size: clamp(1.75rem,3vw,2.75rem); line-height: .95; letter-spacing: -.04em;
    color: #EAE6DE; margin: 0;
  }
  .el-body { font-family: 'Manrope', system-ui, sans-serif; font-size: 13px; line-height: 1.65; color: rgba(234,230,222,.55); font-weight: 500; }
  .el-sub  { font-family: 'Manrope', system-ui, sans-serif; font-size: 12px; line-height: 1.6;  color: rgba(234,230,222,.32); }
  .el-cta  {
    display: inline-flex; align-items: center; margin-top: .6rem;
    padding: .55rem 1.1rem; font-family: 'Manrope', system-ui, sans-serif;
    font-size: 12px; font-weight: 500; text-decoration: none;
    border: 1px solid; border-radius: 100px; align-self: flex-start;
    transition: opacity .2s, background .2s;
  }
  .el-cta:hover { opacity: .8; background: rgba(255,255,255,.05); }

  @media (max-width: 640px) {
    .el-head { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .el-nav  { align-self: flex-end; }
    .el-sub  { display: none; }
  }

  :focus-visible { outline: 3px solid #A8D5C2; outline-offset: 3px; border-radius: 4px; }

  @media (prefers-reduced-motion: reduce) {
    .el-card { transition: none !important; opacity: 1 !important; }
    .el-img  { transition: none !important; }
  }
</style>

<script>
(function(){
  const rm   = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.el-card'))
  const dots  = Array.from(document.querySelectorAll<HTMLButtonElement>('.el-dot'))
  const prev  = document.getElementById('el-prev')  as HTMLButtonElement
  const next  = document.getElementById('el-next')  as HTMLButtonElement
  const N     = cards.length
  let active  = 0
  let busy    = false

  // Gap in px — matches CSS --cg (1.5rem). We read it live so it's always correct.
  function gap(): number {
    return parseFloat(getComputedStyle(document.documentElement).fontSize) * 1.5
  }

  // Read card width from its actual rendered width — called at transition time (not init).
  function cardW(): number {
    return cards[0]?.offsetWidth ?? 300
  }

  // ── Navigate to index ──
  function goTo(idx: number, instant = false) {
    if (busy && !instant) return
    const newActive = ((idx % N) + N) % N
    if (newActive === active && !instant) return
    busy = true
    active = newActive

    // ARIA
    cards.forEach((c,i) => c.setAttribute('aria-hidden', String(i !== active)))
    dots.forEach((d,i)  => {
      d.classList.toggle('el-dot--active', i === active)
      d.setAttribute('aria-selected', String(i === active))
    })

    const g   = (window as any).gsap
    const cw  = cardW()
    const g_  = gap()
    const dur = instant || rm ? 0 : 0.55
    const ease= 'power3.inOut'

    cards.forEach((card, i) => {
      const isAct   = i === active
      const offsetX = (i - active) * (cw + g_)

      if (g) {
        g.to(card, {
          xPercent: -50,
          x: offsetX,
          scale:   isAct ? 1   : 0.88,
          opacity: isAct ? 1   : 0.4,
          duration: dur,
          ease,
          zIndex: isAct ? 5 : 1,
          boxShadow: isAct ? '0 32px 64px rgba(0,0,0,.55)' : '0 0 0 rgba(0,0,0,0)',
          onComplete: () => { if (isAct) busy = false }
        })
      } else {
        card.style.transform = `translateX(calc(-50% + ${offsetX}px))`
        card.style.opacity   = isAct ? '1'     : '0.4'
        card.style.transform = `translateX(calc(-50% + ${offsetX}px)) scale(${isAct ? 1 : 0.88})`
        if (isAct) busy = false
      }
    })
    if (!g) busy = false
  }

  // ── Init: position all cards after layout ──
  const init = () => {
    const g = (window as any).gsap
    if (!g) { setTimeout(init, 60); return }

    // Wait for layout so offsetWidth is accurate
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const cw = cardW()
        const g_ = gap()

        cards.forEach((card, i) => {
          const isAct   = i === 0
          const offsetX = i * (cw + g_)  // card 0 at center, others to the right
          g.set(card, {
            xPercent: -50,
            x: offsetX,
            scale:   isAct ? 1   : 0.88,
            opacity: isAct ? 1   : 0.4,
            zIndex:  isAct ? 5   : 1,
            boxShadow: isAct ? '0 32px 64px rgba(0,0,0,.55)' : '0 0 0 rgba(0,0,0,0)',
          })
        })

        // Also fix deck container height to match first card
        const deck = document.getElementById('el-deck')
        if (deck && cards[0]) {
          deck.style.height = cards[0].offsetHeight + 'px'
        }
      })
    })
  }

  if ((window as any).gsap) init()
  else window.addEventListener('load', init)

  // Resize: recalculate positions
  let resizeTimer: ReturnType<typeof setTimeout>
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer)
    resizeTimer = setTimeout(() => {
      requestAnimationFrame(() => goTo(active, true))
    }, 150)
  })

  // ── Controls ──
  prev.addEventListener('click', () => goTo(active - 1))
  next.addEventListener('click', () => goTo(active + 1))
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)))

  // Click on non-active card
  cards.forEach((card, i) => {
    card.addEventListener('click', () => { if (i !== active) goTo(i) })
  })

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (document.activeElement?.closest('#elements')) {
      if (e.key === 'ArrowLeft')  { e.preventDefault(); goTo(active - 1) }
      if (e.key === 'ArrowRight') { e.preventDefault(); goTo(active + 1) }
    }
  })

  // Drag / swipe
  const deck = document.getElementById('el-deck')
  if (deck && window.matchMedia('(pointer: coarse), (pointer: fine)').matches) {
    let startX = 0, dragging = false
    deck.addEventListener('pointerdown', (e) => { startX = e.clientX; dragging = true })
    deck.addEventListener('pointermove', (e) => {
      if (!dragging) return
      const g = (window as any).gsap
      if (!g) return
      const dx = e.clientX - startX
      const cw = cardW(), g_ = gap()
      cards.forEach((card, i) => {
        g.set(card, { x: (i - active) * (cw + g_) + dx })
      })
    }, { passive: true })
    const endDrag = (e: PointerEvent) => {
      if (!dragging) return
      dragging = false
      const dx = e.clientX - startX
      if      (dx < -60) goTo(active + 1)
      else if (dx >  60) goTo(active - 1)
      else               goTo(active, true)  // snap back
    }
    deck.addEventListener('pointerup',     endDrag)
    deck.addEventListener('pointercancel', () => { dragging = false; goTo(active, true) })
  }
})()
</script>

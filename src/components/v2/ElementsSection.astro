---
// V2 ElementsSection — GSAP card deck.
// All 4 cards occupy the same 100svh slot; cards slide out upward as you scroll,
// revealing the next card beneath. Total scroll height: 4 * 100vh = 400vh pin.
// Replaces the "4 full-height stacked sections" (too much vertical space).
const elements = [
  { id:'earth', number:'01', name:'Earth',
    body:'Strandzha oak, ancient limestone, the smell of forest floor after rain.',
    image:'/images/earth.jpg', alt:'Dense Strandzha forest floor at dusk', accent:'#8B6F4A' },
  { id:'water', number:'02', name:'Water',
    body:'The Black Sea does not perform. It waits. Twelve nations meet at its floor.',
    image:'/images/water.jpg', alt:'Black Sea shoreline at calm morning', accent:'#4A7B8B' },
  { id:'fire',  number:'03', name:'Fire',
    body:'Copper light. The hour before it all goes dark. Dinner as the longest part of the day.',
    image:'/images/fire.jpg',  alt:'Sunset over the Bulgarian Black Sea coast', accent:'#8B5A3A' },
  { id:'air',   number:'04', name:'Air',
    body:'On the cliff edge, wind decides the day. Open sky. Space that opens your chest.',
    image:'/images/air.jpg',   alt:'Open sky above sea cliffs, wide horizon', accent:'#4A8B7A' },
]
---

<section id="elements" aria-labelledby="elements-heading">
  <h2 id="elements-heading" class="sr-only">The four elements of Green Horizon</h2>

  <!-- Section label above the deck -->
  <div class="elements-label-row" aria-hidden="true">
    <span class="elements-label">The Four Elements</span>
    <span class="elements-label">Scroll to explore →</span>
  </div>

  <!-- Pin wrapper: controls total scroll distance (400vh) -->
  <div id="elements-pin-wrapper">
    <!-- Sticky container: stays at top while scrolling -->
    <div id="elements-sticky">

      <!-- Progress bar -->
      <div class="elements-progress" aria-hidden="true">
        <div class="elements-progress-bar" id="elements-progress-bar"></div>
      </div>

      <!-- Card deck: all 4 cards absolutely positioned on top of each other -->
      <div class="elements-deck" id="elements-deck">
        {elements.map((el, i) => (
          <article
            class="element-card"
            id={`el-card-${el.id}`}
            data-index={i}
            aria-label={`${el.number} — ${el.name}: ${el.body}`}
            style={`z-index: ${elements.length - i};`}
          >
            <!-- Full-bleed image -->
            <img src={el.image} alt={el.alt} class="el-card-img" loading={i === 0 ? 'eager' : 'lazy'} />

            <!-- Dark overlay gradient -->
            <div class="el-card-overlay" aria-hidden="true"></div>

            <!-- Content -->
            <div class="el-card-content">
              <!-- Number + name -->
              <div class="el-card-header">
                <span class="el-number" style={`color: ${el.accent};`}>{el.number}</span>
                <h3 class="el-name">{el.name}</h3>
              </div>
              <p class="el-body">{el.body}</p>
            </div>

            <!-- Card index indicator (bottom-right corner) -->
            <div class="el-card-index" aria-hidden="true">
              {el.number} / 04
            </div>
          </article>
        ))}
      </div>

    </div>
  </div>
</section>

<!-- Mobile: simple vertical list (no pinning) -->
<section id="elements-mobile" aria-labelledby="elements-mobile-heading" class="elements-mobile-section">
  <h2 id="elements-mobile-heading" class="sr-only">The four elements</h2>
  {elements.map(el => (
    <article class="el-mobile-item" aria-label={`${el.name}: ${el.body}`}>
      <img src={el.image} alt={el.alt} class="el-mobile-img" loading="lazy" />
      <div class="el-mobile-content">
        <span class="el-number" style={`color: ${el.accent};`}>{el.number}</span>
        <h3 class="el-name">{el.name}</h3>
        <p class="el-body">{el.body}</p>
      </div>
    </article>
  ))}
</section>

<style>
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}

  /* Section label row */
  .elements-label-row{
    display:flex;justify-content:space-between;align-items:center;
    padding:.75rem clamp(1.5rem,4vw,4rem);
    background:#182118;
    border-bottom:1px solid rgba(234,230,222,.07);
  }
  .elements-label{
    font-family:'Manrope',system-ui,sans-serif;font-size:11px;font-weight:500;
    letter-spacing:.14em;text-transform:uppercase;color:rgba(234,230,222,.38);
  }

  /* Pin wrapper: 400vh = 4 cards × 100vh */
  #elements-pin-wrapper{height:400vh;}
  #elements-sticky{
    position:sticky;top:0;width:100%;height:100svh;
    overflow:hidden;background:#111816;
  }

  /* Progress bar */
  .elements-progress{
    position:absolute;top:0;left:0;right:0;height:2px;
    background:rgba(234,230,222,.07);z-index:10;
  }
  .elements-progress-bar{
    height:100%;width:0%;
    background:#A8D5C2;
    transition:none;
  }

  /* Card deck */
  .elements-deck{position:relative;width:100%;height:100%;}

  /* Individual cards — all stacked at position:absolute, same inset */
  .element-card{
    position:absolute;inset:0;
    overflow:hidden;
  }
  .el-card-img{
    width:100%;height:100%;
    object-fit:cover;object-position:center;
    filter:saturate(.85) contrast(1.06) brightness(.9);
  }
  .el-card-overlay{
    position:absolute;inset:0;
    background:linear-gradient(
      to top,
      rgba(17,24,22,.85) 0%,
      rgba(17,24,22,.3)  40%,
      rgba(17,24,22,.15) 70%,
      transparent        100%
    );
  }

  /* Card content */
  .el-card-content{
    position:absolute;bottom:0;left:0;right:0;
    padding:clamp(2rem,4vh,4rem) clamp(1.5rem,4vw,4rem);
  }
  .el-card-header{
    display:flex;align-items:baseline;gap:1rem;margin-bottom:.75rem;
  }
  .el-number{
    font-family:'DM Serif Display',Georgia,serif;
    font-style:italic;font-size:1.1rem;
  }
  .el-name{
    font-family:'Manrope',system-ui,sans-serif;
    font-weight:900;
    font-size:clamp(3rem,8vw,7rem);
    line-height:.9;
    letter-spacing:-.04em;
    color:#EAE6DE;
    margin:0;
  }
  .el-body{
    font-family:'Manrope',system-ui,sans-serif;
    font-size:15px;line-height:1.7;
    color:rgba(234,230,222,.65);
    max-width:40ch;
    margin-top:.75rem;
  }
  .el-card-index{
    position:absolute;top:1.5rem;right:clamp(1.5rem,4vw,4rem);
    font-family:'Manrope',system-ui,sans-serif;
    font-size:11px;letter-spacing:.14em;
    color:rgba(234,230,222,.3);
  }

  /* Desktop: show pin, hide mobile */
  @media(min-width:769px){
    #elements-mobile{display:none;}
  }

  /* Mobile: hide pin, show simple list */
  @media(max-width:768px){
    #elements-pin-wrapper,.elements-label-row{display:none;}
    .elements-mobile-section{display:block;}
  }

  /* Mobile styles */
  .el-mobile-item{
    position:relative;min-height:70svh;
    display:flex;flex-direction:column;justify-content:flex-end;
    overflow:hidden;background:#111816;
  }
  .el-mobile-img{
    position:absolute;inset:0;width:100%;height:100%;
    object-fit:cover;filter:saturate(.8) brightness(.85);
  }
  .el-mobile-content{
    position:relative;z-index:1;
    padding:3rem 1.5rem;
    background:linear-gradient(to top,rgba(17,24,22,.9) 0%,transparent 100%);
  }
</style>

<script>
  const rm  = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const mob = window.matchMedia('(max-width: 768px)').matches

  if(!mob && !rm){
    const init = () => {
      const g  = (window as any).gsap
      const ST = (window as any).ScrollTrigger
      if(!g || !ST){setTimeout(init,60);return}

      const cards   = Array.from(document.querySelectorAll<HTMLElement>('.element-card'))
      const progBar = document.getElementById('elements-progress-bar')
      const total   = cards.length

      // Stack cards: card 0 (bottom) starts visible; cards 1-3 start peeking slightly from below
      cards.forEach((card, i) => {
        if(i === 0) return // First card stays put until scrolled
        g.set(card, { yPercent: 100 }) // Start off-screen below
      })

      // Master scroll driver
      const masterTl = g.timeline({
        scrollTrigger: {
          trigger: '#elements-pin-wrapper',
          pin: '#elements-sticky',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 0.8,
          onUpdate: (self: any) => {
            if(progBar) progBar.style.width = (self.progress * 100) + '%'
          }
        }
      })

      // Each card slides up and exits, revealing the one beneath
      // Transition spans 1/(total-1) of total scroll each
      cards.forEach((card, i) => {
        if(i === total - 1) return // Last card never exits
        const start = i / (total - 1)
        const end   = (i + 1) / (total - 1)

        // Slide next card up from below
        if(cards[i + 1]) {
          masterTl.fromTo(cards[i + 1],
            { yPercent: 100 },
            { yPercent: 0, ease: 'power2.inOut', duration: end - start },
            start
          )
        }

        // Slightly compress and dim the exiting card
        masterTl.fromTo(card,
          { scale: 1, filter: 'brightness(1)' },
          { scale: .97, filter: 'brightness(.7)', ease: 'power2.in', duration: (end - start) * 0.4 },
          start + (end - start) * 0.6
        )
      })
    }
    if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init)
    else init()
  }
</script>

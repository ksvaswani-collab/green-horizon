---
// V2 ElementsSection — GSAP card deck: one card visible at a time.
// Cards slide up to reveal the next as you scroll through a 400vh pin.
const elements = [
  { id:'earth', number:'01', name:'Earth',
    body:'Strandzha oak, ancient limestone, the smell of forest floor after rain.',
    image:'/images/earth.jpg',
    alt:'Dense Strandzha ancient forest floor at dusk', accent:'#B8956A' },
  { id:'water', number:'02', name:'Water',
    body:'The Black Sea does not perform. It waits. Twelve nations meet at its floor.',
    image:'/images/water.jpg',
    alt:'Black Sea shoreline at calm morning', accent:'#6AB8C8' },
  { id:'fire', number:'03', name:'Fire',
    body:'Copper light. The hour before it all goes dark. Dinner as the longest part of the day.',
    image:'/images/fire.jpg',
    alt:'Golden sunset over the Bulgarian Black Sea coast', accent:'#C8846A' },
  { id:'air', number:'04', name:'Air',
    body:'On the cliff edge, wind decides the day. Open sky. Space that opens your chest.',
    image:'/images/air.jpg',
    alt:'Open sky above sea cliffs, wide horizon', accent:'#6AC8A8' },
]
---

<section id="elements" aria-labelledby="elements-hdg">
  <h2 id="elements-hdg" class="sr-only">The four elements of Green Horizon</h2>

  <!-- Label bar -->
  <div class="el-label-bar" aria-hidden="true">
    <span>The Four Elements</span>
    <span class="el-label-hint">Scroll to reveal →</span>
  </div>

  <!-- Desktop: pinned deck -->
  <div id="el-pin-wrap">
    <div id="el-sticky">

      <!-- Progress: 4 dots -->
      <div class="el-dots" aria-hidden="true" id="el-dots">
        {elements.map((_,i)=>(
          <span class={`el-dot${i===0?' el-dot--active':''}`} data-dot={i}></span>
        ))}
      </div>

      <!-- Stack of cards -->
      <div id="el-deck">
        {elements.map((el,i)=>(
          <article
            class="el-card"
            id={`el-card-${i}`}
            aria-label={`${el.number} — ${el.name}: ${el.body}`}
          >
            <img src={el.image} alt={el.alt} class="el-card-img" loading={i===0?'eager':'lazy'} />
            <div class="el-card-scrim" aria-hidden="true"></div>
            <div class="el-card-body">
              <div class="el-card-top">
                <span class="el-num" style={`color:${el.accent}`}>{el.number}</span>
                <span class="el-of">/ 04</span>
              </div>
              <h3 class="el-name">{el.name}</h3>
              <p  class="el-desc">{el.body}</p>
            </div>
          </article>
        ))}
      </div>

    </div>
  </div>

  <!-- Mobile: simple vertical stacked panels -->
  <div id="el-mobile" aria-label="The four elements">
    {elements.map(el=>(
      <article class="el-mob-panel" aria-label={`${el.name}: ${el.body}`}>
        <img src={el.image} alt={el.alt} class="el-mob-img" loading="lazy" />
        <div class="el-mob-scrim" aria-hidden="true"></div>
        <div class="el-card-body">
          <span class="el-num" style={`color:${el.accent}`}>{el.number}</span>
          <h3 class="el-name">{el.name}</h3>
          <p  class="el-desc">{el.body}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;}

  /* Label bar */
  .el-label-bar{
    display:flex;justify-content:space-between;align-items:center;
    padding:.7rem clamp(1.5rem,4vw,4rem);
    background:#182118;
    border-bottom:1px solid rgba(234,230,222,.07);
    font-family:'Manrope',system-ui,sans-serif;
    font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;
    color:rgba(234,230,222,.35);
  }

  /* Pin wrapper */
  #el-pin-wrap{height:400vh;}
  #el-sticky{
    position:sticky;top:0;
    width:100%;height:100svh;
    overflow:hidden;background:#111816;
  }

  /* Dot navigation */
  .el-dots{
    position:absolute;bottom:2.5rem;right:clamp(1.5rem,4vw,4rem);
    display:flex;flex-direction:column;gap:.6rem;
    z-index:10;
  }
  .el-dot{
    width:5px;height:5px;
    border-radius:50%;
    background:rgba(234,230,222,.25);
    transition:background .3s ease,transform .3s ease;
  }
  .el-dot--active{background:#A8D5C2;transform:scale(1.4);}

  /* Card deck */
  #el-deck{position:relative;width:100%;height:100%;}

  /* Cards all stack at same position */
  .el-card{
    position:absolute;inset:0;
    overflow:hidden;
    /* Cards 1-3 start translated down (set by JS) */
  }
  .el-card-img{
    width:100%;height:100%;
    object-fit:cover;object-position:center;
    filter:saturate(.82) contrast(1.08);
  }
  .el-card-scrim{
    position:absolute;inset:0;
    background:linear-gradient(to top,rgba(17,24,22,.88) 0%,rgba(17,24,22,.2) 50%,rgba(17,24,22,.05) 100%);
  }
  .el-card-body{
    position:absolute;bottom:0;left:0;right:0;
    padding:clamp(2rem,4vh,4rem) clamp(1.5rem,4vw,4rem);
  }
  .el-card-top{display:flex;align-items:baseline;gap:.75rem;margin-bottom:.5rem;}
  .el-num{font-family:'DM Serif Display',Georgia,serif;font-style:italic;font-size:1.1rem;}
  .el-of{font-family:'Manrope',system-ui,sans-serif;font-size:11px;letter-spacing:.1em;color:rgba(234,230,222,.3);}
  .el-name{
    font-family:'Manrope',system-ui,sans-serif;font-weight:900;
    font-size:clamp(3.5rem,9vw,8rem);line-height:.9;letter-spacing:-.04em;
    color:#EAE6DE;margin:0 0 1rem;
  }
  .el-desc{
    font-family:'Manrope',system-ui,sans-serif;font-size:15px;line-height:1.7;
    color:rgba(234,230,222,.6);max-width:38ch;
  }

  /* Mobile */
  @media(min-width:769px){#el-mobile{display:none;}}
  @media(max-width:768px){
    #el-pin-wrap,.el-label-bar{display:none;}
    #el-mobile{display:block;}
  }
  .el-mob-panel{position:relative;min-height:75svh;overflow:hidden;background:#111816;}
  .el-mob-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:saturate(.8);}
  .el-mob-scrim{position:absolute;inset:0;background:linear-gradient(to top,rgba(17,24,22,.9) 0%,transparent 60%);}
  .el-mob-panel .el-card-body{position:relative;}
</style>

<script>
  const rm  = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const mob = window.matchMedia('(max-width: 768px)').matches

  if(!mob){
    const init = () => {
      const g  = (window as any).gsap
      const ST = (window as any).ScrollTrigger
      if(!g || !ST){setTimeout(init,80);return}

      const cards = Array.from(document.querySelectorAll<HTMLElement>('.el-card'))
      const dots  = document.querySelectorAll<HTMLElement>('.el-dot')
      const N = cards.length

      // All cards except first start below the viewport
      cards.slice(1).forEach(c => g.set(c,{yPercent:100}))

      // Build a timeline: N-1 transitions, each takes 1 "unit"
      const tl = g.timeline()

      for(let i=0;i<N-1;i++){
        // Outgoing card: compress upward & dim
        tl.to(cards[i],{yPercent:-8,scale:.97,filter:'brightness(.65)',duration:.5,ease:'power2.in'},i)
        // Incoming card: slide up from below
        tl.to(cards[i+1],{yPercent:0,duration:.6,ease:'power2.inOut'},i+.4)
      }

      // Pin and scrub
      ST.create({
        trigger:'#el-pin-wrap',
        start:'top top',
        end:'bottom bottom',
        pin:'#el-sticky',
        scrub:1,
        animation:tl,
        onUpdate:(self:any)=>{
          // Update active dot
          const active = Math.min(N-1, Math.floor(self.progress * N))
          dots.forEach((d,i)=>{
            d.classList.toggle('el-dot--active', i===active)
          })
        }
      })

      // Reduced motion: just show all panels stacked without animation
      if(rm){
        cards.forEach(c=>{g.set(c,{yPercent:0,scale:1,filter:'none'})})
      }
    }
    if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init)
    else init()
  }
</script>

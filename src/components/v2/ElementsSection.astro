---
// V2 ElementsSection — CSS scroll-snap carousel.
// No JS width measurement at init. scroll-snap centers each card perfectly.
// GSAP handles scale + opacity for active/inactive state only.
const elements = [
  { id:'earth', number:'01', name:'Earth',
    body:'Strandzha oak, ancient limestone, the smell of forest floor after rain.',
    sub:'The ancient volcanic cliff — forest floor to the edge.',
    image:'/images/earth.jpg', alt:'Dense Strandzha ancient forest, dark and layered',
    bg:'#141f14', accent:'#B8956A', cta:'Explore Earth' },
  { id:'water', number:'02', name:'Water',
    body:'The Black Sea does not perform. It waits.',
    sub:'Twelve nations meet at its floor.',
    image:'/images/water.jpg', alt:'Black Sea surface at calm morning, dark and still',
    bg:'#0e1a1f', accent:'#6AB8C8', cta:'Explore Water' },
  { id:'fire', number:'03', name:'Fire',
    body:'Copper light. The hour before it all goes dark.',
    sub:'Dinner as the longest part of the day.',
    image:'/images/fire.jpg', alt:'Golden sunset over Bulgarian Black Sea coast',
    bg:'#1f1209', accent:'#C8846A', cta:'Explore Fire' },
  { id:'air', number:'04', name:'Air',
    body:'On the cliff edge, wind decides the day.',
    sub:'Open sky. Space that opens your chest.',
    image:'/images/air.jpg', alt:'Open sky above sea cliffs, wide horizon',
    bg:'#0e1318', accent:'#6AC8A8', cta:'Explore Air' },
]
---

<section id="elements" aria-labelledby="elements-hdg">

  <!-- Header -->
  <header class="el-head">
    <h2 id="elements-hdg" class="el-title">Four ways to feel alive.</h2>
    <div class="el-nav-arrows" role="group" aria-label="Element navigation">
      <button id="el-prev" class="el-arrow" aria-label="Previous element">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M11 13.5L6.5 9L11 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="el-dots" role="tablist" aria-label="Go to element" id="el-dots">
        {elements.map((_,i)=>(
          <button class={`el-dot${i===0?' el-dot--active':''}`} role="tab"
            aria-selected={i===0} aria-label={elements[i].name} data-index={i}></button>
        ))}
      </div>
      <button id="el-next" class="el-arrow" aria-label="Next element">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M7 4.5L11.5 9L7 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </header>

  <!--
    Scroll-snap viewport.
    padding-inline pads both sides so first/last cards can scroll to the horizontal center.
    No JS measurement needed — the browser handles centering natively.
  -->
  <div class="el-viewport" id="el-viewport" aria-live="polite">
    {elements.map((el,i)=>(
      <article
        class={`el-card${i===0?' el-card--active':''}`}
        id={`el-card-${i}`}
        data-index={i}
        style={`background:${el.bg};--accent:${el.accent};`}
        aria-label={`${el.number} of 04 — ${el.name}: ${el.body}`}
        aria-hidden={i!==0}
      >
        <div class="el-img-wrap">
          <img src={el.image} alt={el.alt} class="el-img" loading={i===0?'eager':'lazy'} />
          <div class="el-img-scrim" aria-hidden="true"></div>
        </div>
        <div class="el-card-inner">
          <div class="el-card-meta">
            <span class="el-num" style={`color:${el.accent}`}>{el.number}</span>
            <span class="el-total">/ 04</span>
          </div>
          <h3 class="el-name">{el.name}</h3>
          <p  class="el-body">{el.body}</p>
          <p  class="el-sub">{el.sub}</p>
          <a href="#register" class="el-cta" style={`border-color:${el.accent};color:${el.accent};`}>
            {el.cta} →
          </a>
        </div>
      </article>
    ))}
  </div>

</section>

<style>
  /* ── Card width as a CSS custom property — single source of truth ── */
  :root {
    --el-card-w: clamp(240px, 38vw, 520px);
    --el-card-gap: 1.25rem;
  }
  @media (max-width: 1024px) { :root { --el-card-w: clamp(240px, 48vw, 440px); } }
  @media (max-width: 640px)  { :root { --el-card-w: clamp(220px, 78vw, 300px); } }

  #elements {
    background: #111816;
    padding: 4rem 0 6rem;
  }

  /* ── Header ── */
  .el-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding: 0 clamp(1.5rem,4vw,4rem) 2.5rem;
  }
  .el-title {
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(1.5rem,3vw,2.5rem);
    letter-spacing: -.03em;
    color: #EAE6DE;
    margin: 0; flex: 1;
  }
  .el-nav-arrows {
    display: flex; align-items: center; gap: 1rem; flex-shrink: 0;
  }
  .el-arrow {
    width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(234,230,222,.06);
    border: 1px solid rgba(234,230,222,.12);
    border-radius: 50%;
    color: rgba(234,230,222,.7);
    cursor: pointer;
    transition: background .2s, border-color .2s, color .2s;
  }
  .el-arrow:hover   { background: rgba(234,230,222,.12); color: #EAE6DE; border-color: rgba(234,230,222,.25); }
  .el-arrow:disabled{ opacity: .3; cursor: not-allowed; }
  .el-arrow:focus-visible { outline: 3px solid #A8D5C2; outline-offset: 3px; }
  .el-dots { display: flex; gap: .5rem; align-items: center; }
  .el-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(234,230,222,.2);
    border: none; cursor: pointer; padding: 0;
    transition: background .3s, transform .3s;
  }
  .el-dot--active { background: var(--accent, #A8D5C2); transform: scale(1.3); }
  .el-dot:focus-visible { outline: 2px solid #A8D5C2; outline-offset: 3px; border-radius: 50%; }

  /* ── Scroll-snap viewport ──
     padding-inline = (100vw - card-width) / 2  →  first/last card centers exactly.
     No JS width measurement needed. ── */
  .el-viewport {
    display: flex;
    gap: var(--el-card-gap);
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;        /* Firefox */
    -ms-overflow-style: none;     /* IE/Edge */
    /* The side padding centers each card when scrolled to */
    padding-inline: calc((100% - var(--el-card-w)) / 2);
    /* Align items at the start so cards don't get clipped */
    align-items: flex-start;
    cursor: grab;
  }
  .el-viewport::-webkit-scrollbar { display: none; }
  .el-viewport:active { cursor: grabbing; }

  /* ── Cards ── */
  .el-card {
    flex-shrink: 0;
    width: var(--el-card-w);
    scroll-snap-align: center;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(234,230,222,.06);
    /* Non-active: scaled down and faded — GSAP will override */
    opacity: .4;
    transform: scale(.88);
    transition: box-shadow .4s ease;
  }
  .el-card--active {
    opacity: 1;
    transform: scale(1);
    box-shadow: 0 32px 64px rgba(0,0,0,.55);
    border-color: rgba(234,230,222,.12);
    z-index: 2;
  }

  /* Image area */
  .el-img-wrap {
    position: relative; width: 100%; aspect-ratio: 3/2; overflow: hidden;
  }
  .el-img {
    width: 100%; height: 100%; object-fit: cover;
    filter: saturate(.72) contrast(1.06) brightness(.85);
    transition: filter .5s, transform .6s;
  }
  .el-card--active .el-img  { filter: saturate(.9) contrast(1.04) brightness(.95); }
  .el-card--active:hover .el-img { transform: scale(1.03); }
  .el-img-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 55%, rgba(0,0,0,.55) 100%);
  }

  /* Card body */
  .el-card-inner { padding: 1.1rem 1.4rem 1.5rem; display: flex; flex-direction: column; gap: .4rem; }
  .el-card-meta  { display: flex; align-items: baseline; gap: .5rem; margin-bottom: .2rem; }
  .el-num  { font-family: 'DM Serif Display', Georgia, serif; font-style: italic; font-size: .9rem; }
  .el-total{ font-family: 'Manrope', system-ui, sans-serif; font-size: 10px; letter-spacing: .1em; color: rgba(234,230,222,.25); }
  .el-name {
    font-family: 'Manrope', system-ui, sans-serif; font-weight: 900;
    font-size: clamp(1.75rem,3vw,2.75rem); line-height: .95; letter-spacing: -.04em;
    color: #EAE6DE; margin: 0;
  }
  .el-body { font-family: 'Manrope', system-ui, sans-serif; font-size: 13px; line-height: 1.65; color: rgba(234,230,222,.55); font-weight: 500; }
  .el-sub  { font-family: 'Manrope', system-ui, sans-serif; font-size: 12px; line-height: 1.6; color: rgba(234,230,222,.32); }
  .el-cta  {
    display: inline-flex; align-items: center; margin-top: .6rem;
    padding: .55rem 1.1rem; font-family: 'Manrope', system-ui, sans-serif;
    font-size: 12px; font-weight: 500; text-decoration: none;
    border: 1px solid; border-radius: 100px; align-self: flex-start;
    transition: opacity .2s, background .2s;
  }
  .el-cta:hover { opacity: .8; background: rgba(255,255,255,.05); }

  /* Mobile: hide subtitle */
  @media (max-width: 640px) {
    .el-head { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .el-nav-arrows { align-self: flex-end; }
    .el-sub { display: none; }
    .el-card { transform: scale(.93); }
    .el-card--active { transform: scale(1); }
  }

  :focus-visible { outline: 3px solid #A8D5C2; outline-offset: 3px; border-radius: 4px; }

  @media (prefers-reduced-motion: reduce) {
    .el-card, .el-img { transition: none !important; transform: none !important; }
    .el-card { opacity: 1 !important; }
  }
</style>

<script>
(function(){
  const rm       = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const viewport = document.getElementById('el-viewport') as HTMLElement
  const cards    = Array.from(document.querySelectorAll<HTMLElement>('.el-card'))
  const dots     = Array.from(document.querySelectorAll<HTMLButtonElement>('.el-dot'))
  const prevBtn  = document.getElementById('el-prev') as HTMLButtonElement
  const nextBtn  = document.getElementById('el-next') as HTMLButtonElement
  const N        = cards.length
  let active     = 0

  if (!viewport) return

  // ── Set active card with GSAP scale + opacity ──
  function setActive(index: number) {
    const newActive = ((index % N) + N) % N
    if (newActive === active && !rm) return
    active = newActive

    // ARIA updates
    cards.forEach((c, i) => c.setAttribute('aria-hidden', String(i !== active)))
    dots.forEach((d, i) => {
      d.classList.toggle('el-dot--active', i === active)
      d.setAttribute('aria-selected', String(i === active))
    })

    const g = (window as any).gsap
    if (g && !rm) {
      cards.forEach((card, i) => {
        const isAct = i === active
        g.to(card, { scale: isAct ? 1 : 0.88, opacity: isAct ? 1 : 0.4, duration: 0.45, ease: 'power2.out' })
      })
    } else {
      cards.forEach((card, i) => {
        card.style.transform = i === active ? 'scale(1)' : 'scale(0.88)'
        card.style.opacity   = i === active ? '1'        : '0.4'
      })
    }
    cards.forEach((c, i) => c.classList.toggle('el-card--active', i === active))
  }

  // ── Scroll to a card by index ──
  function scrollToCard(index: number) {
    const idx = ((index % N) + N) % N
    const card = cards[idx]
    if (!card) return
    // scrollIntoView centers the card natively — no measurement needed
    card.scrollIntoView({ behavior: rm ? 'instant' : 'smooth', inline: 'center', block: 'nearest' })
    setActive(idx)
  }

  // ── IntersectionObserver: detect which card is centered ──
  // Fires when a card's center enters the scroll-snap viewport
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting && e.intersectionRatio >= 0.5) {
          const idx = parseInt((e.target as HTMLElement).dataset.index ?? '0', 10)
          if (idx !== active) setActive(idx)
        }
      })
    },
    { root: viewport, threshold: 0.5 }
  )
  cards.forEach(c => observer.observe(c))

  // ── Arrow navigation ──
  prevBtn.addEventListener('click', () => scrollToCard(active - 1))
  nextBtn.addEventListener('click', () => scrollToCard(active + 1))

  // ── Dot navigation ──
  dots.forEach((dot, i) => dot.addEventListener('click', () => scrollToCard(i)))

  // ── Keyboard navigation ──
  viewport.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft')  { e.preventDefault(); scrollToCard(active - 1) }
    if (e.key === 'ArrowRight') { e.preventDefault(); scrollToCard(active + 1) }
  })

  // Initial state without GSAP (pure CSS handles it via .el-card--active)
  // GSAP syncs once it's loaded
  const syncGsap = () => {
    const g = (window as any).gsap
    if (!g) return
    cards.forEach((card, i) => {
      g.set(card, { scale: i === active ? 1 : 0.88, opacity: i === active ? 1 : 0.4, clearProps: '' })
    })
  }
  if ((window as any).gsap) syncGsap()
  else window.addEventListener('load', syncGsap)
})()
</script>

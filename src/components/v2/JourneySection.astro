---
// V2 JourneySection — "Dispatches from the cliff."
// Full-width cinematic images dominate each entry. Dates as giant ambient typography.
// No alternating columns. No generic grid.
const entries = [
  {
    dateDisplay:'NOV — 2024',
    dateShort:'11',
    heading:'Ground broken',
    dispatch:'The first foundations poured. Chalk and clay soil. Nothing moved that does not have to be.',
    image:'/images/build-nov-2024.jpg',
    alt:'Early foundation work on the cliff site, November 2024',
  },
  {
    dateDisplay:'MAR — 2025',
    dateShort:'03',
    heading:'Walls find form',
    dispatch:'Raw frames emerge. The structure follows the cliff contour, stepping down rather than imposing.',
    image:'/images/build-march-2025.jpg',
    alt:'Concrete walls of Green Horizon rising, March 2025',
  },
  {
    dateDisplay:'JUN — 2025',
    dateShort:'06',
    heading:'The roof closes',
    dispatch:'Watertight. The first time the building reads as a whole. The view from the terrace: exactly what was hoped.',
    image:'/images/build-june-2025.jpg',
    alt:'Completed roof structure with sea view, June 2025',
  },
]
---

<section id="journey" aria-labelledby="journey-hdg">

  <!-- Masthead -->
  <div class="jn-head">
    <div class="jn-head-left">
      <p class="jn-overline">The Build</p>
      <h2 id="journey-hdg" class="jn-title">Dispatches<br>from the cliff.</h2>
    </div>
    <div class="jn-head-right">
      <div class="jn-stat"><span class="jn-stat-n">4</span><span class="jn-stat-l">Rooms</span></div>
      <div class="jn-stat"><span class="jn-stat-n">6</span><span class="jn-stat-l">Villas</span></div>
      <div class="jn-stat"><span class="jn-stat-n">2026</span><span class="jn-stat-l">Opening</span></div>
    </div>
  </div>

  <!-- Entries: full-width cinematic dispatches -->
  <div class="jn-entries">
    {entries.map((e,i)=>(
      <article class="jn-entry jn-reveal" aria-label={`${e.dateDisplay}: ${e.heading}`}>

        <!-- Cinematic wide image — full width, short height -->
        <div class="jn-img-wrap">
          <img src={e.image} alt={e.alt} loading="lazy" class="jn-img" />
          <!-- Large ambient date inside the image -->
          <span class="jn-date-ambient" aria-hidden="true">{e.dateShort}</span>
        </div>

        <!-- Dispatch text row below the image -->
        <div class="jn-text-row">
          <p class="jn-date-label">{e.dateDisplay}</p>
          <div class="jn-text-main">
            <h3 class="jn-heading">{e.heading}</h3>
            <p class="jn-body">{e.dispatch}</p>
          </div>
          <span class={`jn-index`}>{String(i+1).padStart(2,'0')}</span>
        </div>

      </article>
    ))}
  </div>

  <div class="jn-footer">
    <a href="#register" class="jn-cta">Follow the build — register interest →</a>
  </div>

</section>

<style>
  #journey{background:#111816;padding:5rem 0 6rem;}

  /* Masthead */
  .jn-head{
    display:flex;align-items:flex-end;justify-content:space-between;gap:2rem;flex-wrap:wrap;
    padding:0 clamp(1.5rem,4vw,4rem) 3rem;
    border-bottom:1px solid rgba(234,230,222,.07);
    margin-bottom:0;
  }
  .jn-overline{font-family:'Manrope',system-ui,sans-serif;font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:#A8D5C2;margin-bottom:.75rem;}
  .jn-title{font-family:'Manrope',system-ui,sans-serif;font-weight:900;font-size:clamp(2rem,4vw,3.5rem);line-height:1.05;letter-spacing:-.03em;color:#EAE6DE;margin:0;}
  .jn-head-right{display:flex;gap:2.5rem;align-items:flex-end;flex-shrink:0;}
  .jn-stat{display:flex;flex-direction:column;align-items:flex-end;}
  .jn-stat-n{font-family:'DM Serif Display',Georgia,serif;font-style:italic;font-size:clamp(2.5rem,4vw,3.5rem);line-height:1;color:#A8D5C2;}
  .jn-stat-l{font-family:'Manrope',system-ui,sans-serif;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:rgba(234,230,222,.3);}

  /* Entries */
  .jn-entries{display:flex;flex-direction:column;}

  .jn-entry{
    border-bottom:1px solid rgba(234,230,222,.06);
    opacity:0;transform:translateY(28px);
    transition:opacity .7s ease,transform .7s ease;
  }
  .jn-entry.jn-visible{opacity:1;transform:none;}

  /* Cinematic image — full width, aspect-ratio 21:6 (very wide, short) */
  .jn-img-wrap{
    position:relative;
    width:100%;
    aspect-ratio:21/6;
    overflow:hidden;
  }
  .jn-img{
    width:100%;height:100%;
    object-fit:cover;object-position:center 40%;
    filter:saturate(.7) contrast(1.1) brightness(.85);
    transition:transform .8s ease,filter .6s ease;
  }
  .jn-entry:hover .jn-img{transform:scale(1.02);filter:saturate(.85) contrast(1.05);}

  /* Ambient date — huge, faint, inside image */
  .jn-date-ambient{
    position:absolute;
    right:clamp(1rem,3vw,3rem);bottom:-.1em;
    font-family:'Manrope',system-ui,sans-serif;
    font-weight:900;
    font-size:clamp(6rem,14vw,16rem);
    line-height:1;
    color:rgba(234,230,222,.07);
    letter-spacing:-.05em;
    pointer-events:none;user-select:none;
  }

  /* Text row */
  .jn-text-row{
    display:grid;
    grid-template-columns:auto 1fr auto;
    gap:2rem;align-items:start;
    padding:1.75rem clamp(1.5rem,4vw,4rem);
  }
  .jn-date-label{
    font-family:'Manrope',system-ui,sans-serif;
    font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;
    color:#A8D5C2;padding-top:.2rem;white-space:nowrap;
  }
  .jn-text-main{display:flex;flex-direction:column;gap:.5rem;}
  .jn-heading{
    font-family:'Manrope',system-ui,sans-serif;font-weight:800;
    font-size:clamp(1.1rem,2vw,1.5rem);line-height:1.2;letter-spacing:-.02em;
    color:#EAE6DE;margin:0;
  }
  .jn-body{
    font-family:'Manrope',system-ui,sans-serif;
    font-size:14px;line-height:1.7;
    color:rgba(234,230,222,.5);max-width:52ch;
  }
  .jn-index{
    font-family:'DM Serif Display',Georgia,serif;font-style:italic;
    font-size:1.5rem;color:rgba(234,230,222,.15);
    align-self:start;margin-top:.1rem;
  }

  /* Footer */
  .jn-footer{padding:3rem clamp(1.5rem,4vw,4rem) 0;text-align:right;}
  .jn-cta{
    font-family:'Manrope',system-ui,sans-serif;font-size:13px;font-weight:500;
    color:#A8D5C2;text-decoration:none;
    border-bottom:1px solid rgba(168,213,194,.3);padding-bottom:2px;
    transition:border-color .2s ease;
  }
  .jn-cta:hover{border-color:#A8D5C2;}
  :focus-visible{outline:3px solid #A8D5C2;outline-offset:3px;border-radius:4px;}

  /* Mobile */
  @media(max-width:640px){
    .jn-text-row{grid-template-columns:1fr;gap:1rem;}
    .jn-index{display:none;}
    .jn-img-wrap{aspect-ratio:16/7;}
    .jn-head-right{gap:1.5rem;}
  }

  @media(prefers-reduced-motion:reduce){
    .jn-entry{opacity:1!important;transform:none!important;}
  }
</style>

<script>
  const init = () => {
    const entries = document.querySelectorAll('.jn-reveal')
    if(!entries.length) return
    const obs = new IntersectionObserver(
      es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('jn-visible');obs.unobserve(e.target)}}),
      {threshold:.12}
    )
    entries.forEach(el=>obs.observe(el))
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init)
  else init()
</script>

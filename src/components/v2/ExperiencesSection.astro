---
// V2 ExperiencesSection — numbered rows + sticky image panel on desktop
const experiences = [
  {
    number: '01',
    title: 'Strandzha Walks',
    body: 'Into the oldest national park on Bulgaria\'s Black Sea coast. Boar tracks in the mud, wild orchids in season, complete quiet.',
    image: '/images/exp-forest.jpg',
    alt: 'Ancient forest path in Strandzha national park, dappled morning light through oak trees',
  },
  {
    number: '02',
    title: 'Sunrise on the Dunes',
    body: 'The dunes south of the hotel reach the water\'s edge. At 5am, before the heat arrives, the light is unlike anything else.',
    image: '/images/exp-dunes.jpg',
    alt: 'Golden sunrise light over sand dunes beside the Black Sea, long shadows',
  },
  {
    number: '03',
    title: 'The Sea at Dusk',
    body: 'The cliff path ends at a small promontory. Every evening the light does something different. That is the experience.',
    image: '/images/exp-sea.jpg',
    alt: 'Dramatic dusk view from sea cliff, dark water below, copper sky',
  },
]
---
<section id="experiences" aria-labelledby="exp-heading" class="exp-section">
  <div class="exp-inner">
    <!-- Rows column -->
    <div class="exp-rows">
      <h2 id="exp-heading" class="exp-section-label">Experiences</h2>

      {experiences.map((exp, i) => (
        <article
          class="exp-row"
          data-exp-index={i}
          aria-label={`Experience: ${exp.title}`}
        >
          <div class="exp-row-inner">
            <div class="exp-number-col">
              <span class="exp-number" aria-hidden="true">{exp.number}</span>
            </div>
            <div class="exp-text-col">
              <h3 class="exp-title">{exp.title}</h3>
              <p class="exp-body">{exp.body}</p>
            </div>
          </div>
          <div class="exp-row-border" aria-hidden="true"></div>

          <!-- Mobile-only image -->
          <div class="exp-mobile-img">
            <img
              src={exp.image}
              alt={exp.alt}
              loading="lazy"
            />
          </div>
        </article>
      ))}
    </div>

    <!-- Desktop sticky image panel -->
    <div class="exp-image-panel" aria-hidden="true" id="exp-image-panel">
      {experiences.map((exp, i) => (
        <img
          src={exp.image}
          alt=""
          class={`exp-panel-img ${i === 0 ? 'is-active' : ''}`}
          data-exp-img={i}
          loading="lazy"
        />
      ))}
    </div>
  </div>
</section>

<style>
  .exp-section {
    background: #272420;
    padding: 8rem clamp(2rem, 6vw, 8rem);
    position: relative;
  }

  .exp-inner {
    display: grid;
    grid-template-columns: 1fr 40%;
    gap: 4rem;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
  }

  .exp-rows {
    display: flex;
    flex-direction: column;
  }

  .exp-section-label {
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7A8C84;
    margin-bottom: 3rem;
  }

  .exp-row {
    position: relative;
  }

  .exp-row-inner {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    padding: 3rem 0;
  }

  .exp-row-border {
    height: 1px;
    background: rgba(234, 230, 222, 0.1);
  }

  .exp-number {
    font-family: 'Lora', Georgia, serif;
    font-style: italic;
    font-size: clamp(2rem, 3vw, 2.5rem);
    color: #7A8C84;
    line-height: 1;
    display: block;
    padding-top: 0.1em;
  }

  .exp-title {
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    letter-spacing: -0.02em;
    color: #EAE6DE;
    margin-bottom: 0.75rem;
    line-height: 1.1;
    transition: color 0.2s ease;
  }

  .exp-row:hover .exp-title {
    color: #A8D5C2;
  }

  .exp-body {
    font-family: 'Manrope', system-ui, sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: #7A8C84;
    line-height: 1.75;
    max-width: 48ch;
  }

  /* Mobile image (hidden on desktop) */
  .exp-mobile-img {
    display: none;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }

  .exp-mobile-img img {
    width: 100%;
    height: 260px;
    object-fit: cover;
  }

  /* Desktop sticky image panel */
  .exp-image-panel {
    position: sticky;
    top: 20vh;
    height: 60vh;
    overflow: hidden;
    flex-shrink: 0;
    align-self: flex-start;
  }

  .exp-panel-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .exp-panel-img.is-active {
    opacity: 1;
  }

  :focus-visible {
    outline: 2px solid #A8D5C2;
    outline-offset: 4px;
  }

  @media (max-width: 900px) {
    .exp-inner {
      grid-template-columns: 1fr;
    }

    .exp-image-panel {
      display: none;
    }

    .exp-mobile-img {
      display: block;
    }

    .exp-row-inner {
      grid-template-columns: 56px 1fr;
      gap: 1.25rem;
    }
  }

  @media (max-width: 600px) {
    .exp-row-inner {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .exp-number {
      font-size: 1.25rem;
    }
  }
</style>

<script>
  (function () {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    const initAnim = () => {
      const g = (window as any).gsap
      const ST = (window as any).ScrollTrigger
      if (!g || !ST) return

      const rows = document.querySelectorAll('.exp-row')
      const panelImgs = document.querySelectorAll('.exp-panel-img')

      if (!rows.length || !panelImgs.length) return

      // Swap images as each row enters viewport
      rows.forEach((row, i) => {
        ST.create({
          trigger: row,
          start: 'top 50%',
          end: 'bottom 50%',
          onEnter: () => swapImage(i),
          onEnterBack: () => swapImage(i),
        })
      })

      function swapImage(idx: number) {
        panelImgs.forEach((img, i) => {
          if (i === idx) {
            img.classList.add('is-active')
          } else {
            img.classList.remove('is-active')
          }
        })
      }
    }

    if ((window as any).gsap && (window as any).ScrollTrigger) {
      initAnim()
    } else {
      window.addEventListener('load', initAnim)
    }
  })()
</script>

---
interface Props { t: any; lang?: string }
const { t } = Astro.props
---
<section id="contact" class="v1-cta">

  <!-- Gradient bridge: dissolves from limestone Rooms above into dark CTA -->
  <div class="v1-cta-fade" aria-hidden="true"></div>

  <div class="v1-cta-inner">

    <div class="v1-cta-meta">
      <p class="v1-cta-coords">42°N · 27°E · Black Sea, Bulgaria</p>
      <p class="v1-cta-year">Opening 2026</p>
    </div>

    <div class="v1-cta-body-row">
      <h2 class="v1-cta-heading">{t.register.heading}</h2>
      <div class="v1-cta-side">
        <p class="v1-cta-body">{t.register.body}</p>
        <div class="v1-cta-actions">
          <button type="button" class="btn btn-primary-inv v1-cta-btn">
            {t.register.cta}
            <span class="arr" aria-hidden="true">→</span>
          </button>
          <p class="v1-cta-note">{t.register.note}</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .v1-cta {
    position: relative;
    background: var(--color-midnight);
    padding: 0 clamp(1.5rem, 4vw, 6rem) 9rem;
    overflow: hidden;
  }

  .v1-cta-fade {
    height: 8rem;
    background: linear-gradient(to bottom, var(--color-limestone), var(--color-midnight));
    margin: 0 calc(-1 * clamp(1.5rem, 4vw, 6rem));
    margin-bottom: 4rem;
  }

  .v1-cta-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .v1-cta-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .v1-cta-coords {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--color-copper);
    text-transform: uppercase;
  }

  .v1-cta-year {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: rgba(232,228,220,0.3);
    text-transform: uppercase;
  }

  .v1-cta-body-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media(min-width: 900px) {
    .v1-cta-body-row {
      grid-template-columns: 1fr 1fr;
      align-items: end;
      gap: 5rem;
    }
  }

  .v1-cta-heading {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(40px, 5.5vw, 80px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-linen);
  }

  .v1-cta-side {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .v1-cta-body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-seafoam);
  }

  .v1-cta-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .v1-cta-note {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: rgba(197,212,206,0.45);
  }

  .v1-cta::after {
    content: 'HORIZON';
    position: absolute;
    right: clamp(1.5rem, 4vw, 6rem);
    bottom: -1rem;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(6rem, 14vw, 18rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: rgba(232,228,220,0.03);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }
</style>

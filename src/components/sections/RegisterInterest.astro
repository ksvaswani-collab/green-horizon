---
interface Props { t: any; lang?: string }
const { t, lang = 'en' } = Astro.props
---
<!-- Lightest section — linen surface, dark text -->
<section id="contact" style="background:var(--color-surface);padding:8rem clamp(1.5rem,4vw,6rem);border-top:1px solid var(--color-border);">
  <div style="max-width:38rem;margin:0 auto;">
    <h2 style="font-family:var(--font-display);font-weight:300;font-size:clamp(32px,4vw,56px);line-height:1.1;letter-spacing:-0.01em;color:var(--color-midnight);margin-bottom:1.5rem;">{t.register.heading}</h2>
    <p style="font-family:var(--font-body);font-size:16px;line-height:1.75;color:var(--color-forest);margin-bottom:3rem;">{t.register.body}</p>

    <form name="register-interest" method="POST" data-netlify="true" netlify-honeypot="bot-field"
      style="display:flex;flex-direction:column;gap:1.5rem;" id="reg-form">
      <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>
      <input type="hidden" name="locale" value={lang} />
      <div class="fr">
        <input type="text" name="firstname" placeholder={t.register.fields.firstname} required autocomplete="given-name" class="fi" />
        <input type="text" name="lastname"  placeholder={t.register.fields.lastname}  required autocomplete="family-name" class="fi" />
      </div>
      <input type="email" name="email" placeholder={t.register.fields.email} required autocomplete="email" class="fi" style="display:block;width:100%;" />
      <div style="position:relative;">
        <select name="interest" class="fi" style="appearance:none;-webkit-appearance:none;width:100%;cursor:pointer;background:transparent;color:var(--color-midnight);">
          <option value="" disabled selected>{t.register.fields.interest}</option>
          {t.register.fields.interest_options.map((o: string) => (<option value={o}>{o}</option>))}
        </select>
        <span aria-hidden="true" style="position:absolute;right:0;top:50%;transform:translateY(-50%);pointer-events:none;font-size:10px;color:var(--color-muted);">↓</span>
      </div>
      <textarea name="note" placeholder={t.register.fields.note} rows="3" class="fi" style="resize:none;width:100%;display:block;"></textarea>
      <button type="submit" class="fs">{t.register.submit}</button>
    </form>
    <p style="font-family:var(--font-mono);font-size:11px;color:var(--color-copper);letter-spacing:0.15em;margin-top:1.5rem;">{t.register.note}</p>
  </div>
</section>

<style>
  .fr{display:grid;grid-template-columns:1fr;gap:1.5rem;}
  @media(min-width:480px){.fr{grid-template-columns:1fr 1fr;gap:1rem;}}
  .fi{background:transparent;border:none;border-bottom:1px solid rgba(13,17,23,0.2);padding:0.75rem 0;font-family:var(--font-body);font-size:16px;color:var(--color-midnight);outline:none;transition:border-color 0.3s ease;}
  .fi::placeholder{color:var(--color-muted);font-family:var(--font-body);}
  .fi:focus{border-bottom-color:var(--color-copper);}
  .fi option{background:var(--color-linen);color:var(--color-midnight);}
  .fs{width:100%;padding:1rem;background:var(--color-midnight);color:var(--color-linen);font-family:var(--font-mono);font-size:11px;letter-spacing:0.15em;text-transform:uppercase;border:none;cursor:pointer;transition:opacity 0.3s ease;margin-top:0.5rem;}
  .fs:hover{opacity:0.8;}
  .fs:focus-visible{outline:2px solid var(--color-copper);outline-offset:2px;}
</style>

<script>
  const form = document.getElementById('reg-form') as HTMLFormElement | null
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      try {
        const res = await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(new FormData(form) as any).toString() })
        if (res.ok) form.innerHTML = `<div style="padding:3rem 0;"><p style="font-family:var(--font-display);font-size:1.5rem;color:var(--color-midnight);font-weight:300;margin-bottom:1rem;">We have your interest.</p><p style="font-family:var(--font-body);font-size:15px;color:var(--color-forest);">Hanneke will be in touch personally.</p></div>`
      } catch { form.submit() }
    })
  }
</script>

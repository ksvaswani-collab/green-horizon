---
interface Props { t: any; lang?: string }
const { t } = Astro.props
---
<section id="contact" class="v1-cta">
  <div class="v1-cta-inner">
    <p class="v1-cta-coords">42°N · 27°E · Black Sea, Bulgaria</p>
    <h2 class="v1-cta-heading">{t.register.heading}</h2>
    <p class="v1-cta-body">{t.register.body}</p>
    <a href="#" class="btn btn-primary-inv v1-cta-btn">
      {t.register.cta}
      <span class="arr" aria-hidden="true">→</span>
    </a>
    <p class="v1-cta-note">{t.register.note}</p>
  </div>
</section>

<style>
  .v1-cta {
    background: #2B4A3C;
    padding: 9rem clamp(1.5rem, 4vw, 6rem);
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .v1-cta-inner {
    max-width: 42rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .v1-cta-coords {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--color-copper);
    text-transform: uppercase;
  }
  .v1-cta-heading {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.08;
    letter-spacing: -0.01em;
    color: var(--color-linen);
    margin-bottom: 0.25rem;
  }
  .v1-cta-body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-seafoam);
    max-width: 36rem;
  }
  .v1-cta-btn {
    margin-top: 0.5rem;
  }
  .v1-cta-note {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: rgba(197, 212, 206, 0.55);
    margin-top: 0.25rem;
  }
</style>

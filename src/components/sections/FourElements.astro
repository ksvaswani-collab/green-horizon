---
interface Props { t: any }
const { t } = Astro.props

const els = [
  {
    key: 'earth', idx: '01',
    bg: 'var(--color-earth-light)', accent: '#8B6F5C',
    textHead: 'var(--color-midnight)', textBody: '#4A4035', textLabel: '#8B7B6B',
    data: t.elements.earth, img: '/images/earth.jpg', alt: 'Cliff soil and ancient forest floor',
  },
  {
    key: 'water', idx: '02',
    bg: 'var(--color-water-light)', accent: '#2E5F7A',
    textHead: 'var(--color-midnight)', textBody: '#2D3F4A', textLabel: '#6B7C85',
    data: t.elements.water, img: '/images/water.jpg', alt: 'Black Sea surface at dusk',
  },
  {
    key: 'fire', idx: '03',
    bg: 'var(--color-fire-light)', accent: '#C2603A',
    textHead: 'var(--color-midnight)', textBody: '#4A2E22', textLabel: '#8B6055',
    data: t.elements.fire, img: '/images/fire.jpg', alt: 'Open fire close-up',
  },
  {
    key: 'air', idx: '04',
    bg: 'var(--color-air-light)', accent: '#4A6B5A',
    textHead: 'var(--color-midnight)', textBody: '#2D3F35', textLabel: '#6B7C72',
    data: t.elements.air, img: '/images/air.jpg', alt: 'Horizon line — sea meets sky',
  },
]
---

<section id="elements" class="v1-elements-section">
  <div id="epw" class="ep-wrap">
    <div id="es" class="ep-sticky">
      <div id="et" class="ep-track">
        {els.map(el => (
          <div
            class="ep"
            style={`--ep-bg:${el.bg};--ep-accent:${el.accent};--ep-text-head:${el.textHead};--ep-text-body:${el.textBody};--ep-text-label:${el.textLabel};`}
          >
            <span class="ep-label">{el.idx} {el.data.title.toUpperCase()}</span>
            <div class="ep-text">
              <div class="ep-accent-line" aria-hidden="true"></div>
              <h2 class="eh ep-heading">{el.data.title}</h2>
              <p class="eb ep-body">{el.data.body}</p>
            </div>
            <div class="ep-img-col">
              <img src={el.img} alt={el.alt} loading="lazy" class="ep-img" />
              <div class="ep-img-fade" aria-hidden="true"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="em">
    {els.map(el => (
      <div
        class="em-panel"
        style={`--ep-bg:${el.bg};--ep-accent:${el.accent};--ep-text-head:${el.textHead};--ep-text-body:${el.textBody};--ep-text-label:${el.textLabel};`}
      >
        <img src={el.img} alt={el.alt} loading="lazy" class="em-img" />
        <div class="em-content">
          <div class="ep-accent-line" aria-hidden="true"></div>
          <span class="em-idx">{el.idx}</span>
          <h2 class="em-heading">{el.data.title}</h2>
          <p class="em-body">{el.data.body}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .v1-elements-section { position: relative; }

  .ep { background: var(--ep-bg); }
  .ep-label { color: var(--ep-text-label); }
  .ep-accent-line { background: var(--ep-accent); }
  .eh { color: var(--ep-text-head); }
  .eb { color: var(--ep-text-body); }
  .ep-img-fade { background: linear-gradient(to right, var(--ep-bg), transparent); }
  .em-panel { background: var(--ep-bg); }
  .em-idx, .em-heading { color: var(--ep-text-head); }
  .em-body { color: var(--ep-text-body); }
  .em-panel .ep-accent-line { background: var(--ep-accent); }

  .ep-wrap { height: 400vh; }
  .ep-sticky { position: sticky; top: 0; width: 100%; height: 100svh; overflow: hidden; display: flex; }
  .ep-track { display: flex; width: 400vw; height: 100%; will-change: transform; }
  .ep { width: 100vw; height: 100%; display: flex; align-items: center; position: relative; }

  .ep-label {
    position: absolute; top: 2rem; left: clamp(1.5rem,4vw,4rem);
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.15em; text-transform: uppercase;
  }
  .ep-text { padding-left: clamp(1.5rem,8vw,8rem); max-width: 50%; position: relative; z-index: 2; }
  .ep-accent-line { width: 2rem; height: 2px; margin-bottom: 1.5rem; }
  .ep-heading {
    font-family: var(--font-display); font-weight: 300;
    font-size: clamp(80px,10vw,140px); line-height: 0.9;
    opacity: 0; transform: translateX(40px);
  }
  .ep-body {
    font-family: var(--font-body); font-size: 16px; line-height: 1.75;
    margin-top: 1.5rem; max-width: 22rem; opacity: 0;
  }
  .ep-img-col { position: absolute; right: 0; top: 0; width: 45%; height: 100%; overflow: hidden; }
  .ep-img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.55) contrast(1.05) brightness(1.05); }
  .ep-img-fade { position: absolute; top: 0; left: 0; width: 6rem; height: 100%; }

  .em { display: none; }
  .em-panel { min-height: 100svh; display: flex; flex-direction: column; justify-content: flex-end; position: relative; padding: 4rem 1.5rem; }
  .em-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: saturate(0.5) contrast(1.05) brightness(1.05); opacity: 0.3; }
  .em-content { position: relative; z-index: 2; }
  .em-panel .ep-accent-line { width: 1.5rem; margin-bottom: 1.25rem; }
  .em-idx { display: block; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 0.75rem; }
  .em-heading { font-family: var(--font-display); font-weight: 300; font-size: clamp(3rem,12vw,6rem); line-height: 1; margin-bottom: 1.25rem; }
  .em-body { font-family: var(--font-body); font-size: 15px; line-height: 1.7; max-width: 24rem; }

  @media (max-width: 767px) {
    #epw { display: none !important; }
    .em { display: block !important; }
  }
</style>

<script>
  const rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  const mob = window.matchMedia('(max-width: 767px)').matches

  if (!mob && !rm) {
    const init = () => {
      const g = (window as any).gsap
      const ST = (window as any).ScrollTrigger
      if (!g || !ST) { setTimeout(init, 50); return }

      const track = document.getElementById('et')
      const hls = document.querySelectorAll<HTMLElement>('.eh')
      const bds = document.querySelectorAll<HTMLElement>('.eb')
      if (!track) return

      let last = -1

      ST.create({
        trigger: '#epw', start: 'top 80%', once: true,
        onEnter: () => {
          if (last === -1) {
            last = 0
            if (hls[0]) g.to(hls[0], { opacity: 1, x: 0, duration: 0.6, ease: 'power3.out' })
            if (bds[0]) g.to(bds[0], { opacity: 1, duration: 0.6, delay: 0.12, ease: 'power2.out' })
          }
        },
      })

      g.to('#et', {
        x: () => -(track.scrollWidth - window.innerWidth),
        ease: 'none',
        scrollTrigger: {
          trigger: '#epw', pin: '#es', scrub: 1,
          start: 'top top', end: 'bottom bottom',
          onUpdate: (s: any) => {
            const pi = Math.min(3, Math.floor(s.progress * 4))
            if (pi === last) return
            last = pi
            if (hls[pi]) g.to(hls[pi], { opacity: 1, x: 0, duration: 0.6, ease: 'power3.out' })
            if (bds[pi]) g.to(bds[pi], { opacity: 1, duration: 0.6, delay: 0.12, ease: 'power2.out' })
          },
        },
      })

      ST.create({
        trigger: '#epw', start: 'bottom bottom',
        onEnter: () => { if (track) track.style.willChange = 'auto' },
      })
    }

    document.readyState === 'loading'
      ? document.addEventListener('DOMContentLoaded', init)
      : init()
  }
</script>
